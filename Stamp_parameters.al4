METHOD need_bitmap_24(
{Bitmap} in_b|itmap) ==> {Bitmap_24}, NEW
    :
    RESULT = in_b.{Bitmap_24} 
    CASE RESULT != NONE ? ==> ;
    RESULT = New_bitmap_24(in_b.Width, .Height, Holder)
    in_b.Draw(RESULT.Canvas, Pt(0,0))
    Erase_frac(RESULT) .

    
METHOD Downscale(
{Bitmap_direct} B|mp_source, INT N|umber_times) ==> {Bitmap_direct}, NEW
    :
	CASE B.{Bitmap_24} != NONE ? 
		 {Bitmap_24} b|24_bitmap_B = B.{Bitmap_24}     
	     RESULT = New_bitmap_24(B.Width / N, B.Height / N, Holder)
	     {Bitmap_24} r|24_bitmap_RESULT = RESULT.{Bitmap_24}
    	 FOR y IN [0 TO RESULT.Height-1] :
    	     r.Lock_rows(y, 1, FALSE)
    	     b.Lock_rows(y * N, N, TRUE) 
    	 	 INT to|_RESULT_position = 0
    	 	 FOR x IN [0 TO RESULT.Width-1] <--------------------------
    	 	     REAL avg|_from_NxN_values = 0
    	 	     FOR yy IN [0 TO N-1] :
    	 	         INT fr|rom_byte_position = yy * b.Row_width + x * N * 3
	    	 	     FOR xx IN [0 TO N - 1] :
	    	 	         avg += b.Pixels[fr+2].Int
	    	 	         		+ b.Pixels[fr+1].Int/256.0
	    	 	         		+ b.Pixels[fr].Int/65536.0 ;
    	 	     ;
    	 	     avg = _ / (N * N)
    	 	     //CASE avg >= 255.999 ? avg = 255.999 ;
    	 	     r.Pixels[to+2] = avg.Int.Byte
    	 	     r.Pixels[to+1] = (avg*256).Int.Byte
    	 	     r.Pixels[to] = (avg*65536).Int.Byte
    	 	     to += 3
    	 	 ---------------------------------------------------------->
    	 	 b.Unlock(FALSE)
    	 	 r.Unlock(TRUE)
    	 ;
	ELSE RESULT = New_bitmap_direct(B.Width / N, B.Height / N, 24) 
	     B.Stretch_draw(RESULT.Canvas, {rect}(W=RESULT.Width.Pixels_to_points,
	    	 H=RESULT.Height.Pixels_to_points)) 
	; 
    Main_.Satellite_param.Thumbnails.Invalidate_all .
    

METHOD retouch|_by_rescale(
{Bitmap_direct} b|itmap_input) ==> {Bitmap_direct}, NEW :
	{Bitmap} temp|_bitmap = New_bitmap(b.Width * 111 / 100, b.Height * 111 / 100,
		24)
		
	b.Stretch_draw(temp.Canvas, {rect}(W= temp.Width.Pixels_to_points,
		H= temp.Height.Pixels_to_points))
		
	RESULT = New_bitmap_direct(b.Width, b.Height, 24)
		
    temp.Stretch_draw(RESULT.Canvas, {rect}(W= b.Width.Pixels_to_points,
        H= b.Height.Pixels_to_points)) .

METHOD shift_horizontal(
{Bitmap_direct} b|itmpap_bitmap_image,
INT delta|_pixels)
    :
    INT bytes_pp|ixel = b.Bpp/8
    BYTE sav|e_pixel0[].Allocate(3)     
    FOR y IN [0 TO b.Height-1] :
    	CASE y % 10 == 0 ? 
    	     Progress_1.Set_progress(70 + y * 30.0 / b.Height)
    	     Long_operation.Indicate(TRUE) ;
        b.Lock_rows(y, 1, TRUE)
        INT xx|_position_in_row = 0
        INT x_s|ource = xx - delta * bytes_pp
        sav[0] = b.Pixels[0]
        sav[1] = b.Pixels[1]
        sav[2] = b.Pixels[2]
    	FOR x IN [b.Width-1 DOWNTO 0] :
    	    ---------------------------- 'fix__x_s', REUSED
	        CASE ?
	        [x_s < 0 ] ? x_s += b.Row_width 
	        [x_s >= b.Row_width] ? x_s -= b.Row_width ;
	        ----------------------------
    		CASE x != 0 ? 
	    		 b.Pixels[xx] = b.Pixels[x_s]
	    		 b.Pixels[xx+1] = b.Pixels[x_s+1]
	    		 b.Pixels[xx+2] = b.Pixels[x_s+2]
    		ELSE b.Pixels[xx] = sav[0]
    			 b.Pixels[xx+1] = sav[1]
    			 b.Pixels[xx+2] = sav[2]
    		;
    		CASE delta > 0 ? 
    		     xx -= bytes_pp 
    		     x_s -= bytes_pp 
    		ELSE 
    		     xx += bytes_pp 
    		     x_s += bytes_pp 
    		;
    		LIKE ......... 'fix__x_s', BUT (x_s==>xx)*?
    	;
        b.Unlock(TRUE)
    ; .

METHOD shift_vertical(
{Bitmap_direct} b|itmpap_bitmap_image,
INT delta|_pixels)
    :
	INT bytes_pp|ixel = b.Bpp/8
    BYTE buf|er_row[].Allocate(b.Width * bytes_pp)
    INT y_d|estination = 0
    INT y_s|ource = y_d - delta
    ------------------------------- 'save row 0'
    BYTE sav|e_buffer[].Allocate(b.Width * bytes_pp)
    b.Lock_rows(0, 1, TRUE)
    FOR i IN [0 TO b.Row_width-1] : sav[i] = b.Pixels[i] ;
    b.Unlock(FALSE)
    FOR j IN [b.Height-1 DOWNTO 0] :
        CASE j % 10 == 0 ? 
    	     Progress_1.Set_progress(90 + (b.Height - j) * 10.0 / b.Height)
    	     Long_operation.Indicate(TRUE) ;
    	-------------------------------------- 'fix__y_s', REUSED
        CASE ?
        [y_s < 0 ] ? y_s += b.Height 
        [y_s >= b.Height] ? y_s -= b.Height ;
        -------------------------------------
        CASE j != 0 ? 
	         b.Lock_rows(y_s, 1, TRUE)
	         FOR i IN [0 TO b.Row_width-1] : buf[i] = b.Pixels[i] ;
	         b.Unlock(FALSE)
	         b.Lock_rows(y_d, 1, FALSE)
	         FOR i IN [0 TO b.Row_width-1] : b.Pixels[i] = buf[i] ;
	         b.Unlock(TRUE)
        ELSE
	         b.Lock_rows(y_d, 1, FALSE)
	         FOR i IN [0 TO b.Row_width-1] : b.Pixels[i] = sav[i] ;
	         b.Unlock(TRUE)
        ;
		CASE delta > 0 ? 
		     y_d -= 1 
		     y_s -= 1
		ELSE y_d += 1
			 y_s +=1
		;
		LIKE ......... 'fix__y_s', BUT (y_s==>y_d)*?
        //DEBUG: "j=" j " y_s=" y_s  " y_d=" y_d " buf[]:" buf[].Count
        //        " Row_width=" b.Row_width " Height=" b.Height #NL ;
    ; .

METHOD avg_of_next_stamps(
{Bitmap_direct} in_b|itmpap_bitmap_image) ==> {Bitmap_direct}
	:
	{Bitmap_24} b|itmap_in|TEMP = need_bitmap_24(in_b)
	RESULT = b
	{Bitmap_24} seq|uence_TEMP[]
	FOR i IN [Main_.Current_image TO Main_.All_images[].Count-1] :
	    {Bitmap} b_i|mage_to_checj_size = Main_.All_images[i] 
		CASE b_i.Width != b.Width || b_i.Height != b.Height ?
		     DEBUG: "size of image " i " is different, stop on seq[]: "
		     	"" seq[].Count #NL ;
		     BREAK i ;
	    {Bitmap_24} img_i|_from_all_TEMP = need_bitmap_24(b_i) 
		seq[] << img_i     
	;
	CASE seq[].Count <= 0 ? 
	     message("not enough images to average from current!") ==> ;
	FOR y IN [0 TO b.Height-1] :
		Progress_1.Set_progress(y * 100 / b.Height)
		Long_operation.Indicate(TRUE)
	    b.Lock_rows(y, 1, TRUE)
		FOR i IN [1 TO seq[].Count-1] : seq[i].Lock_rows(y, 1, TRUE) ;
		INT xx|_position = 0
		FOR x IN [0 TO b.Width-1] :
		    REAL avg|_value = b.Pixels[xx+2].Int + b.Pixels[xx+1].Int/256.0
		    				+ b.Pixels[xx].Int/65536.0
		    				
		    FOR i IN [1 TO seq[].Count-1] :
		        avg += seq[i].Pixels[xx+2].Int + seq[i].Pixels[xx+1].Int/256.0
		        		+ seq[i].Pixels[xx].Int/65536.0 ;
		    avg = _ / seq[].Count
			-------------------------- 'store avg value'
			b.Pixels[xx+2] = avg.Int.Byte
			b.Pixels[xx+1] = (avg * 256).Int.Byte
			b.Pixels[xx] = (avg * 65536).Int.Byte
		    xx += 3
		;
		FOR i IN [1 TO seq[].Count-1] : seq[i].Unlock(FALSE) ;
	    b.Unlock(TRUE) 
	;
	.

BOOL Executing|_commands_stored
	
METHOD Execute_commands|_stored_earlier(STR Commands_s|equence[]) :
	PUSH Executing = TRUE :
	     FOR i_c|ommand IN [0 TO Commands_s[].Count-1] :
	         STR instr|uctions[].Split(Commands_s[i_c], ";") 
	    	 CASE instr[0] ? 
	    	 ["CREATE"]:
	    	     FOR j IN [1 TO instr[].Count-1] :
	    	         STR key|_name = instr[j].[0]
	    	         STR val|ue_of_key = instr[j].After("=")
	    	         CASE key ? 
	    	         ["X"]: X_offset.Set_text(val) 
	    	         ["Y"]: Y_offset.Set_text(val) 
	    	         ["V"]: Value.Set_text(val) 
	    	         ["S"]: Shift_final.Set_text(val) 
	    	         ["T"]: Stamp_type.Select(val.Int) 
	    	         ["C"]: Convert_colors.Select(val.Int) 
	    	         ["M"]: Edit_multiplier.Set_text(val) 
	    	         ["U"]: Use_file.Set_checked(val=="TRUE")
	    	         ["R"]: Remove_old_stamp.Set_checked(val=="TRUE")
	    	         ["r"]: Recenter.Set_checked(val=="TRUE")
	    	         ["2"]: Main_.Satellite_param.Use_bitmaps_24 = val=="TRUE"
	    	         ["D"]: Downscale_first.Select(val.Int)
	    	         ;
	    	     ;
	    	     //STR r_current = ""
	    	     {Bitmap} cur|rent_image
		         {Bitmap} fr|om_bitmap
		         {Bitmap_24} temp_b|itmap
	    	     LIKE click .............. 'prepare__to__stamp'
	    	     LIKE click .............. 'do__stamp'
	    	 ["1", "2", "3"]:
	    	 	 CASE instr[0].Int ? 
	    	 	 [1]: pp = Post_processing_1
		         [2]: pp = Post_processing_2 
		         [3]: pp = Post_processing_3  ;
		         r_current = instr[*]
		         pp.Select(instr[1].Int-1)
		         CASE instr[2].Starting("M=") ?
		              val = instr[1].After("=")
		              Edit_multiplier.Set_text(val) ;
		         s_alias = "RUN_POST_PROCESS_" instr[0]
		         LIKE click .............. 'do__stamp'
	    	 ;
	    	 ---------------------- 're-paint'
	    	 Main_.Satellite_param.Thumbnails.Invalidate_all
	    	 Main_.Satellite_param.Process
	    	 Main_.PBox.Invalidate_all
	    	 Main_.Process
	     ;
    ; .


END

