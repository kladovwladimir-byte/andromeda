METHOD List_saved_positions ==> STR :
    {Config} conf|_temp = New_read_config("PlasmaTides", 'USER', "sizes")
    FOR i IN [0 TO 9] :
        CASE !conf.Present("POS_" i.S) ? BREAK i ;
        STR s_pos|ition[].Split(conf.Str("POS_" i.S), " ")
        //DEBUG: << i ": " s_pos[].Merge(", ") #NL ;
    	RESULT = _ "POS_" i.S ":" s_pos[0] "," s_pos[1] " " s_pos[2] " x " s_pos[3]
        RESULT = _ #NL
    ; .
    
