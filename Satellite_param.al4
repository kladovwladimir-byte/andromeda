	------------ 'LABEL_DEVIATION_ANGLE'
	Label_deviation_angle.Set_text("Deviation angle (-90...90)"._Deviation_angle)
	------------ 'LABEL_FINAL_DEVIATION'
	Label_final_deviation.Set_text("Final deviation angle (in perihole)"
	""._Final_deviation_angle)
	------------------- 'LABELARMCOLORS'
	LabelArmColors.Set_text("Spiral arms colors:"._Spiral_arms_colors)
	-------------- 'LABEL_ACTIVITY_TIME'
	Label_activity_time.Set_text("Activity time, years:"._Activity_time)
	-------------- 'LABEL_LAST_ACTIVITY'
	Label_last_activity.Set_text("Skip last activity, years:"._Last_activity)
	------------------- 'LABEL_MAX_DIST'
	Label_max_dist.Set_text("Maximal distance, light-years:"._Max_dist)
	----------------------- 'LABELHINT1'
	LabelHint1.Set_text(
		"Hint: drag center of spiral with CONTROL move to the galaxy center"
		""._Hint1)
	--------------------- 'LABEL_FILTER'
	Label_Filter.Set_text("Filter satellites:"._Filter_satellites)
	--------------- 'LABEL_SPEED_FILTER'
	Label_speed_filter.Set_text("Filter plasma speed"._Filter_plasma_speed)
	------------- 'LABEL_FIRST_ACTIVITY'
	Label_first_activity.Set_text("Skip first activity"._Skip_1st_activity)
	------------------ 'TIME_DISTORTION'
	Time_distortion.Set_text("Time distortion"._Time_distort)
	----------------- 'LOAD_UNDER_IMAGE'
	Load_under_image .Set_text("Load under image"._Load_under_image)
	------------------ 'DRAW_BACKGROUND'
	Draw_background.Set_text("Draw background image"._Draw_background)
	----------------------- '4 combos'
	Satellite_num.Select(0)
	Show_spirals.Select(0)
	Arm_colors.Select(0) 
	----------------------- 'set initial values'
	Edit_name.Set_text("")
	Box_width.Set_text("100000")
	Period_rot.Set_text("100000")
	Eccentricity.Set_text("0.5")
	Mass_BH.Set_text("1000000")
	--------- 'emission'
	Plasma_speed.Set_text("1")
	Final_plasma_speed.Set_text("0.2")
	Deviation_angle.Set_text("90")
	Final_deviation.Set_text("") // "60")
	Cone_angle.Set_text("90")
	Filter_speed.Set_text("")
	--------- 'galactic'
	Edit_tilt.Set_text("0")
	Rotate_proj.Set_text("0")
	Inclination.Set_text("0")
	Starting_angle.Set_text("0")
	Activity_time.Set_text("120000")
	First_activity.Set_text("0")
	Last_activity.Set_text("0")
	--------- 'image'
	Rotate_image.Set_text("0")
	Scale_image.Set_text("100")
	------------------ 'MAKE_SCREENSHOT'
	Make_screenshot.Set_text("Screenshot !"._Make_screenshot)
	INT was_sel|ected = Screenshot_type.Current
	Screenshot_type.Set_items(
	"Usual, as is"._usual_as_is #NL
	""("No lines in odd rows (row is 100 pixels height)"._ss_nolinesoddrows #NL)
	""("No lines in even rows"._ss_nolinesevenrows #NL)
	""("No lines in odd columns (column is 100 pixels width)"._ss_nolinesoddcols 
	#NL)
	""("No lines in even columns"._ss_nolinesevencols #NL)
	""("Double all rows with no lines version"._ss_doublerows #NL)
	""("Gradient visible lines (in)"._Gradient_in #NL)
	""("Gradient visible lines (out)"._Gradient_out #NL)
	""("Gradient visible lines (in+out)"._Gradient_in_out #NL)
	""("Anti-gradient visible lines (in)"._Anti_gradient_in #NL)
	""("Anti-gradient visible lines (out)"._Anti_gradient_out #NL)
	""("Anti-gradient visible lines (in+out)"._Anti_gradient_in_out #NL)
	""("Line around of the spiral, 100 pt wide, no lines"._AroundSpiral100nolines
		#NL)
	""("Line around of the spiral, 100 pt wide, with lines"._AroundSpiral100lines
		#NL)                                                                        
	""("Line around of the spiral, 200 pt wide, no lines"._AroundSpiral200nolines
		#NL)
	""("Line around of the spiral, 200 pt wide, with lines"._AroundSpiral200lines
		)
	)
	Screenshot_type.Select(was_sel)
	
	Grid_options.Set_text("No grid"._No_grid
	""("Grid 100x100, no notes"._Grid100x100)
	""("Grid 200x200, no notes"._Grid200x200)
	""("Grid 100x100, notes on top and left"._Grid100x100topleft)
	""("Grid 200x200, notes on top and left"._Grid200x200topleft)
	""("Grid 100x100, notes each 10 cells"._Grid100x100each10)
	""("Grid 200x200, notes each 10 cells"._Grid200x200each10)
	""("Grid in source, 100x100"._Grid_in_source100x100)
	""("Grid in source, 200x200"._Grid_in_source200x200)
	""("Grid in source, 300x300"._Grid_in_source300x300)
	""("Grid in source, 400x400"._Grid_in_source400x400))
; 
	Fill_scale_rotate .
	
	
METHOD Fill_scale_rotate :
	PUSH in_construct = TRUE :
	CASE ?
	[Scale_rotate_spirals] ?
	     Label_RotateImage.Set_text("Rotate all spirals (0...360)"._RotAllSpirals)
	     Label_ScaleImage.Set_text("Scale spirals, %"._ScaleSpirals)
	[Scale_up_shift] ?
	     Label_RotateImage.Set_text("Rotate all (0...360)"._RotAll)
	     Label_ScaleImage.Set_text("Scale up all, %"._ScaleUpAll)
	ELSE Label_RotateImage.Set_text("Rotate image (0...360):"._Rotate_photo)
	     Label_ScaleImage.Set_text("Scale image, %"._Scale_photo)
	; 
	; .
	
STR all_languages[]
STR current_lang|uage


OVERRIDE moved :
	LIKE after_CONSTRUCT ........ 'bounds', BUT (Restore==>Save) .

OVERRIDE resize :
	LIKE after_CONSTRUCT ........ 'bounds', BUT (Restore==>Save) .
	
OVERRIDE closing ==> {Form}.{action} :
	RESULT = 'DECLINE' 
	Main_.Close .
	
-------------------- '{satellite_param} STRUCTURE'
	
STRUCTURE {satellite_param|eters} :
	STR Name|_of_satellite
    REAL Period|_rotation
    REAL Eccentricity
    REAL Cone_a|ngle
    REAL Tilt|_before_rotate
    REAL Rotate|_projection
    REAL Inclin|ation
    REAL StartA|ngle
    REAL Deviation|_angle
    REAL Deviation_final
    REAL SpeedK|_plasma
    REAL FinalK|_plasma
    REAL Filter_speed|_plasma
    INT ArmsColors
    REAL Activity|_time
    REAL First_ac|tivity
    REAL Last_act|ivity 
    REAL Max_dist|ance
    {point} Center_gal|axy
    ------------------------ 'position on orbit'
    INT Last_i_pos
    .
    
{satellite_param} All_satellites[]
BOOL setting_spiral|_parameters    

OVERRIDE selection_change :
	CASE setting_spiral || in_construct ? ==> ;
    CASE sender_alias ?
    ["SCREENSHOT_TYPE"]: NONE
    ["GRID_OPTIONS"]:
        NxN_in_source = FALSE
        Grid_letters = 0
        CASE Grid_options.Current ? 
        [0]: Grab_to_grid = 0
        [1]: Grab_to_grid = 100
        [2]: Grab_to_grid = 200
        [3]: Grab_to_grid = 100
        	 Grid_letters = 1
        [4]: Grab_to_grid = 200
        	 Grid_letters = 1
        [5]: Grab_to_grid = 100
        	 Grid_letters = 2
        [6]: Grab_to_grid = 100
        	 NxN_in_source = TRUE
        	 Grid_letters = 1
        [7]: Grab_to_grid = 200
        	 NxN_in_source = TRUE
        	 Grid_letters = 1
        [8]: Grab_to_grid = 300
        	 NxN_in_source = TRUE
        	 Grid_letters = 1
        [9]: Grab_to_grid = 400
        	 NxN_in_source = TRUE
        	 Grid_letters = 1
        ;
    ["TRANSPARENCY_SEL"]: Transp = Transparency_sel.Text.Int
    ["LIST_LANG"]: current_lang = all_languages[List_lang.Current]
        //DEBUG: "current lang=" current_lang #NL ;
    	Set_directory_lang(current_lang.Extract_path)
    	STR name_l|anguage = List_lang.Text
    	Localize(name_l.After("_"), "", FALSE)
    	fill_combos
    	--------------------------- 'store in registry'
    	{Config} conf|_temp = New_write_config("Multi-spiral-model", 'USER', "")
    	conf.Set_s("current_lang", name_l)
    ["SHOW_SPIRALS"]: NONE
    ["SATELLITE_NUM"]: 
        selected_satellite
        Main_.Stack_undo[].Clear     
    	Main_.Stack_redo[].Clear     

    ["ARM_COLORS"]:
    	CASE !setting_spiral ? 
    	     All_satellites[Satellite_num.Current].ArmsColors = Arm_colors.Current
    	;
    ; 
    Main_.Invalidate .
    
METHOD selected_satellite :
    CASE setting_spiral || in_construct ? ==> ;
	PUSH setting_spiral = TRUE :
		 {satellite_param} s|piral_selected 
		 s = All_satellites[Satellite_num.Current].CLONE   
	     ---------------------------------- 'center may be local'
	     Main_.Offset_x = s.Center_gal.X
	     Main_.Offset_y = s.Center_gal.Y
              //DEBUG: "selected sat:" Satellite_num.Current 
              //       " move gal center to " s.Center_gal.S #NL 
              //       FOR ss IN All_satellites[] :
              //           << "[sat" ss.INDEX ".Center=" ss.Center_gal.S "]"#NL ;
              //       ;
	     ---------------------------------- 'name'
		 Edit_name.Set_text(s.Name)
		 ---------------------------------- 'galaxy parameters'  
	     Period_rot.Set_text(s.Period.S) 
	     Eccentricity.Set_text(s.Eccentricity.S)
	     Cone_angle.Set_text(s.Cone_a.S)
	     ---------------------------------- 'satellite parameters'
	     Plasma_speed.Set_text(s.SpeedK.S)
	     Final_plasma_speed.Set_text(if_else(s.FinalK.Near(0), "", s.FinalK.S))
	     Filter_speed.Set_text(s.Filter_speed.S)
	     Deviation_angle.Set_text(s.Deviation.S)
	     Final_deviation.Set_text(if_else(s.Deviation_final.Near(0), "",
	     	 s.Deviation_final.S))
	     ---------------------------------- 'active time'
	     Activity_time.Set_text(s.Activity.S)
	     First_activity.Set_text(s.First_ac.S)
	     Last_activity.Set_text(s.Last_act.S)
	     CASE !Same_max_dist ? 
	          Max_dist.Set_text(s.Max_dist.S) ;
	     ---------------------------------- 'view parameters'
	     Edit_tilt.Set_text(s.Tilt.S)
	     Rotate_proj.Set_text(s.Rotate.S)
	     Inclination.Set_text(s.Inclin.S)
	     Starting_angle.Set_text(s.StartA.S)
	     Arm_colors.Select(s.ArmsColors)
	;
    .
    
METHOD hint_a|_large_semiaxis_as_hint(
INT i_s|atellite_index, BOOL set_hint|_text) ==> STR,
OPERATORS({Vector}, {Matrix}), PUBLIC
    :
	{Elliptic_orbit} orbit|_of_satellite
	REAL m_T|_period_multiplyer
	REAL m_a|_coords_multiplyer
	REAL m_M|ass_blak_hole_mult
	{satellite_param} s|piral_sel = All_satellites[i_s].CLONE
	orbit = Main_.get_orbit(s.Eccentricity, FALSE, 0)
	CASE orbit != NONE ? 
    	 m_T = s.Period / T0
    	 m_M = Mass_BH.Text.Real * Sun_mass / Mass_BH0
    	 m_a = (m_T.qq * m_M).Power(1.0/3) / 2
    	 REAL a_max_v|elocity = orbit.Maximal_speed 
    	 .. /= (s.Period / 100_000).Power(1/3.0)
    	 .. *= (Mass_BH.Text.Real / 1000_000).Power(1/3.0)
    	 STR r|esulting_text = "a = " ((orbit.Q_min + .Q_max)*m_a/LY).S_float(4) 
         		" L.Y. q = " (orbit.Q_min*m_a/LY).S_float(4) " L.Y."
         		" v.max=" (a_max_v/1000).Int.S " km/s"
    	 ------------------ 'final tilt angle'
    	 Main_.provide_matrices(s)
    	 {Vector} line_1|_TEMP = Vector_3(0, 0, 1) * Main_.M_transform
    	 REAL a|ngle_inclination = Arccos(line_1.[2]) * 180 / PI
    	 CASE 180 >= a > 90 ? a = a - 180 ;
		 r = _ " tilt:" a.S_float(1)
    	 CASE set_hint ? LabelHint1.Set_text(r) ;
    	 RESULT = r
	; .
	
BOOL Draw_background_image = TRUE
STR Last_box_width

OVERRIDE value_change :
	CASE setting_spiral || in_construct ? 
	     Last_box_width = Box_width.Text ==> ;
	{satellite_param} s|piral_selected 
	s = All_satellites[Satellite_num.Current].CLONE
	PUSH setting_spiral = TRUE :
    CASE sender_alias ?
    ["EDIT_LINE_W", "LABEL_FILE"]: NONE
    ["DRAW_BACKGROUND"]: Draw_background_image = Draw_background.Checked
    ["FILTER_SAT"]: NONE
    ["TIME_DISTORTION"]: NONE
    ["LABELHINT1"]: NONE
    ["EDIT_NAME"]: s.Name = Edit_name.Text
    	BOOL renaming = TRUE
    ["MASS_BH"]: NONE = hint_a(Satellite_num.Current, TRUE)
    ["BOX_WIDTH"]: 
    	CASE Compensate_periods && Last_box_width != "" ?
    		 REAL change|_koeff = (Box_width.Text.Real/Last_box_width.Real)
    		 .. = _.Power(2/3.0)
    		 
    		 FOR sat IN All_satellites[] :
    		 	 DEBUG:
    		 	 	CASE sat.INDEX==Satellite_num.Current ? 
    		 	 	     << "old box=" Last_box_width " new_box=" Box_width.Text
    		 	 	     " k=" change.S " sat.Period:" sat.Period.S 
    		 	 	     "->" (sat.Period * change).S #NL ;
    		 	 ;
    		     sat.Period *= change 
    		     sat.Activity *= change
    		 	 All_satellites[sat.INDEX] = sat.CLONE    
    		 ;
    		 FOR sat IN All_satellites[Satellite_num.Current TO *] :
    		     Activity_time.Set_text(sat.Activity.S)
    		     Period_rot.Set_text(sat.Period.S)
    		     BREAK sat ;
    	;
    	Last_box_width = Box_width.Text
        Main_.Rescale
        Main_.Invalidate ==>
    ["ROTATE_IMAGE", "SCALE_IMAGE"]: 
        Main_.Rescale
        Main_.Invalidate ==>
    ["EDIT_TILT"]: s.Tilt = Edit_tilt.Text.Real
    ["PERIOD_ROT"]: s.Period = Period_rot.Text.Real
    	NONE = hint_a(Satellite_num.Current, TRUE)
    ["ECCENTRICITY"]: s.Eccentricity = Eccentricity.Text.Real
        //DEBUG: "set e=" s.Eccentricity #NL ;
    	s = auto_final_speed(s)
    	NONE = hint_a(Satellite_num.Current, TRUE)
    ["CONE_ANGLE"]: s.Cone_a = Cone_angle.Text.Real
    ["ROTATE_PROJ"]: s.Rotate = Rotate_proj.Text.Real
    ["INCLINATION"]: s.Inclin = Inclination.Text.Real
    ["STARTING_ANGLE"]: s.StartA = Starting_angle.Text.Real
    ["PLASMA_SPEED"]: s.SpeedK = Plasma_speed.Text.Real
    		s = auto_final_speed(s)
    ["FINAL_PLASMA_SPEED"]: s.FinalK = Final_plasma_speed.Text.Real
    ["DEVIATION_ANGLE"]: s.Deviation = Deviation_angle.Text.Real
    ["FINAL_DEVIATION"]: s.Deviation_final = Final_deviation.Text.Real
    ["ACTIVITY_TIME"]: s.Activity = Activity_time.Text.Real
    ["FIRST_ACTIVITY"]: s.First_ac = First_activity.Text.Real
    ["LAST_ACTIVITY"]: s.Last_act = Last_activity.Text.Real
    ["MAX_DIST"]: s.Max_dist = Max_dist.Text.Real
    ["FILTER_SPEED"]: s.Filter_speed = Filter_speed.Text.Real
    ; 
    --------------------------- 'always store center point as local center'
    //DEBUG: "!!!!!!!!!!!!!!!!!!!change " sender_alias" sat "Satellite_num.Current 
    //        "  center to " s.Center_gal.S #NL 
    //         FOR ss IN All_satellites[] :
    //             << ".[sat" ss.INDEX ".Center=" ss.Center_gal.S "]"#NL ;
    //;
    All_satellites[Satellite_num.Current] = s.CLONE
    ;
    CASE !renaming ? Copy_params_same_spiral ;
    need_invalidate = TRUE .
    
METHOD auto_final_speed(
{satellite_param} s|atellite_changing) ==> {satellite_param}
    :
    RESULT = s.CLONE
	CASE !Auto_final_speed ? ==> ;
    REAL k|oeffitient_speed = s.Eccentricity + 1
    RESULT.FinalK = (s.SpeedK * k).Min(1)
    CASE !down_with_shift ? RESULT.FinalK = _.S_float(3).Real ;
    PUSH setting_spiral = TRUE :
         Final_plasma_speed.Set_text(RESULT.FinalK.S_float(2)) ;
    //DEBUG: "--> set FinalK=" RESULT.FinalK " (e=" s.Eccentricity 
    //       ", k=" k ", speed_k=" s.SpeedK ") --> " Final_plasma_speed.Text #NL ;
    need_invalidate = TRUE .
    
BOOL need_invalidate, PUBLIC
STR save_scr|inshot_directory

FUN next_name(STR name|_of_png_file) ==> STR :
	//DEBUG: "next name of [" name "]"#NL ;
    STR ex|tention = name.Ext 
    RESULT = name.Change_ext("") 
    FOR i IN [RESULT.Len-1 DOWNTO 0] :
        CASE "0" <= RESULT.[i] <= "9" ? NONE
        ELSE INT old|_n|umber = RESULT.[i+1 TO *].Int
        	 RESULT = _.[0 TO i] (old+1).S ex 
             //DEBUG: "next is [" RESULT "]"#NL ;
        	 ==> ;
    ;
    RESULT = _ "2" ex .
    
METHOD After_satellite ==> STR
 	:
    FOR sat IN All_satellites[] :
        RESULT << "AFTER_" sat.Index.S ": " (sat.INDEX+1).S 
        	"" if(sat.Name != "", ": " sat.Name) #NL ; .
    

OVERRIDE click :
    CASE sender_alias ?
    ["CHANGE_SCALE"]:
        INT old_sc|ale = Scale_image.Text.Int
        CASE Change_scale.Current ? 
        ["Dec"]: old_sc = (_ - 50).Max(50) / 50 * 50
        ["Inc"]: old_sc = (_ + 50) / 50 * 50 ;
        Scale_image.Set_text(old_sc.S)
    ["SPEED_SWITCH"]:
    	REAL old_s|peed
    	--------------------------------- 'speed__switch', REUSED 
    	old_s = Plasma_speed.Text.Real
        CASE sender.{Paint_turtle}.Current ? 
        ["Dec"]: Plasma_speed.Set_text((old_s - 0.001).Max(0.001).S) 
        ["Inc"]: Plasma_speed.Set_text((old_s + 0.001).Min(1).S)
        ELSE
         	CASE old_s >= 1 ? 
         	     Plasma_speed.Set_text("0.2")
        	ELSE Plasma_speed.Set_text("1") ;
        ;
        ---------------------------------
    ["SPEED_SWITCH_2"]:
    	LIKE .... 'speed__switch', BUT(Plasma==>Final_plasma)*?
    ["LINE_WIDTH_1"]: Edit_line_w.Set_text("1")
    ["BH_MASS_CHANGE"]:
        CASE ?
        [Mass_BH.Text==1_000_000.S] ? Mass_BH.Set_text(4_270_000.S)
        ELSE Mass_BH.Set_text(1_000_000.S)
        ;
    ["STAR_FILTER"]:
        CASE Enable_filtering && Filter_sat.Text=="*" ? 
             Filter_sat.Set_text("#") 
        ELSE Filter_sat.Set_text("*") ;
    	Enable_filtering = TRUE
    ["MAKE_SCREENSHOT"]:
        CASE Screenshot_scale > 200 ?
	         REAL k|oeffitient_scale 
	         k = Screenshot_scale.Pixels_to_points/Main_.PBox.Width
        ELSE k = Screenshot_scale / 100.0 ;
        CASE !Key.Control ? 
	         {Bitmap} bmp|_temp = New_bitmap(
	         	(Main_.PBox.Width * k).Points_to_pixels,
	         	(Main_.PBox.Height * k).Points_to_pixels, 32)
	        	 
	         Main_.View_size = Pt(bmp.Width.Pixels_to_points,
	          					 bmp.Height.Pixels_to_points)
	         DEBUG: "created bitmap " bmp.Width " x " bmp.Height #NL ;
	        	 
    	     PUSH Main_.Paint_squares_NxN :
    	          CASE NxN_in_source ? 
    	               Main_.Paint_squares_NxN = Grab_to_grid;
    	          					  
    	          Main_.Paint_to(bmp.Canvas, TRUE) 
                  //DEBUG: "call Paint_to Paint_squares_NxN=" 
                  // ""Main_.Paint_squares_NxN " Grab_to_grid=" Grab_to_grid #NL 
                  // {Png}.To_file(bmp, "before_grab.png", 100)
                  // ;
    	          
    	     ;
        	 CASE Cell_lines > 0 ? 
        	      {Bitmap} src_c|lear_temp = New_bitmap(
        	        Main_.PBox.Width.Points_to_pixels,
	        	 	Main_.PBox.Height.Points_to_pixels, 32) 
	        	 
        	      PUSH Main_.Skip_all_sat = TRUE :
        	      PUSH Main_.Paint_squares_NxN :
        	           CASE NxN_in_source ? 
        	                Main_.Paint_squares_NxN = Grab_to_grid;
        	      	   Main_.Paint_to(src_c.Canvas, TRUE)
        	      ;
        	      ;
        	 ;
        	 CASE !NxN_in_source { 
    	     CASE Grab_rotated ? 
    	          bmp = bmp.Rotate_flip(90, FALSE, FALSE) ;
    	     PUSH Transp :
    	       CASE Transp==0 ? Transp=98 ;
    	       INT dt|elta_transparency = 17     
    	       CASE Screenshot_type.Current ?
    	       [0]: NONE
    	       [1]: no_lines_in_odd_rows(bmp)
    	       [2]: no_lines_in_even_rows(bmp)
    	       [3]: no_lines_in_odd_cols(bmp)
    	       [4]: no_lines_in_even_cols(bmp)
    	       [5]: bmp = double_all_rows_with_no_lines_rows(bmp)
    	       [6]: bmp = gradient_lines_shot(bmp, -1, Transp, delta_tr=-dt)
    	       [7]: bmp = gradient_lines_shot(bmp, +1, Transp, delta_tr=-dt)
    	       [8]: bmp = gradient_lines_shot(bmp, 0, Transp, delta_tr=-dt)
    	       [9]: bmp = gradient_lines_shot(bmp, -1, 100-Transp, delta_tr=dt)
    	       [10]: bmp = gradient_lines_shot(bmp, +1, 100-Transp, delta_tr=dt)
    	       [11]: bmp = gradient_lines_shot(bmp, 0, 100-Transp, delta_tr=dt)
    	       [12]: bmp = line_around_of_spiral(100, FALSE)
    	       [13]: bmp = line_around_of_spiral(100, TRUE)
    	       [14]: bmp = line_around_of_spiral(200, FALSE)
    	       [15]: bmp = line_around_of_spiral(200, TRUE)
    	       ;
    	     ;
        	 CASE Grab_to_grid > 0 ?
        	      {Bitmap} src|_bitmap = bmp
        	      src.Canvas.Units = 'PIXELS'
        	      src_c.Canvas.Units = 'PIXELS'
        	      INT gg|rid_size = Grab_to_grid
        	      
        	      bmp = New_bitmap(src.Width*(gg+1)/gg, .Height*(gg+1)/gg, 32)
        	      bmp.Canvas...Units = 'PIXELS'
						    ...Background = WHITE
						    ...Erase
						    ...Font.Size = (20 * gg / 50).Pixels_to_points
						    ...Font.Face = "Times New Roman"
        	      INT y_dest|ination = 0
        	      FOR y IN [0 TO src.Height-1] <-------------------------
        	      	  INT x_dest|ination = 0
        	      	  FOR x IN [0 TO src.Width-1] :
        	      	  	  CASE Cell_lines ? 
        	      	  	  [0]: {Canvas} canva|s_source = src.Canvas 
        	      	  	  [1]: 
        	      	  	      	CASE (x/gg+y/gg) % 2 == 1 ? 
        	      	  	      	     canva = src.Canvas
        	      	  	      	ELSE canva = src_c.Canvas ;
        	      	  	  [2]: 
        	      	  	      	CASE (x/gg+y/gg) % 2 != 1 ? 
        	      	  	      	     canva = src.Canvas
        	      	  	      	ELSE canva = src_c.Canvas ;
        	      	  	  ;
        	      	      bmp.Canvas.Copy_rect(
        	      	      		{rect}(Loc=Pt(x_dest,y_dest), W=gg, H=gg),
        	      	      		canva, 
        	      	      		{rect}(Loc=Pt(x, y), W=gg, H=gg))
        	      	      		
        	      	      x_dest += gg+1
        	      	      NEXT x += gg 
        	      	  ;
        	      	  y_dest += gg+1
        	      	  NEXT y += gg
        	      ------------------------------------------------------>

				  PUSH bmp.Canvas.Foreground = WHITE {
					   FOR y IN [-1 TO src.Height-1] <----------------
					       bmp.Canvas.Line(Pt(0, y), Pt(bmp.Width, y))
					       CASE Grid_letters > 0 ?
					            REAL gd_x|_grid_digits = 0
					       	   --------------------- 'grid__digits', REUSED     
        	      	      	   PUSH bmp.Canvas.Foreground = BLACK :
        	      	      	   FOR dd IN [0 TO 1] :
	        	      	           bmp.Canvas.Text(
	        	      	           	 Pt(gd_x+2-dd, 
	        	      	           	  y + gg/2 - 10.Pixels_to_points - dd), 
	        	      	           	 ((y+1)/(gg+1) + 1).S)
	        	      	           	  
        	      	      	   	   bmp.Canvas.Foreground = WHITE
        	      	      	   ;
    	      	               ;
    	      	               ---------------------
        	      	      ;
        	      	      NEXT y += gg+1
					   ----------------------------------------------->
					   FOR x IN [-1 TO src.Width-1] <-----------------
					       bmp.Canvas.Line(Pt(x, 0), Pt(x, bmp.Height))
        	      	       CASE Grid_letters > 0 ?
        	      	       		REAL gd_y|_grid_digits = 0     
        	      	       		STR letter|_to_draw
        	      	       		------------------- 'grid__letters', REUSED
        	      	      	    PUSH bmp.Canvas.Foreground = BLACK :
        	      	      	    FOR dd IN [0 TO 1] :
        	      	      	    	letter = ((x+1)/(gg+1) % 26 + "A".Ord).Char
        	      	      	    	CASE (x+1)/(gg+1) >= 26 ? 
        	      	      	    	     letter = _ ((x+1)/(gg+1) / 26).S ;
	        	      	           	bmp.Canvas.Text(
	        	      	           		Pt(x + gg/2 - 10.Pixels_to_points -dd, 
	        	      	           			gd_y+2-dd), 
	        	      	           		letter)
	        	      	           		
        	      	      	   	    bmp.Canvas.Foreground = WHITE
        	      	      	    ;
    	      	                ;
    	      	                -------------------
        	      	       ;
					       NEXT x += gg+1
					   ----------------------------------------------->
					   CASE Grid_letters==2 && src.Width/gg > 10 ? 
					   		FOR x IN [(gg+1)*10 TO src.Width-gg-1] :
					   		    gd_x = x
					   			FOR y IN [-1 TO src.Height-1] :
					   				LIKE ....... 'grid__digits'
					   				NEXT y += gg+1
					   			;
					   			NEXT x += (gg+1)*10
					   		;
					   		gd_x = ((src.Width*1.0/gg).Int - 1) * (gg+1) + gg*0.8
					   		FOR y IN [-1 TO src.Height-1] :
					   		    LIKE ....... 'grid__digits'
					   		    NEXT y += gg+1
					   		;
					   ;
					   CASE Grid_letters==2 && src.Height/gg > 10 ? 
					   		FOR y IN [(gg+1)*10 TO src.Height-gg-1] :
					   		    gd_y = y
					   			FOR x IN [-1 TO src.Width-1] :
					   				LIKE ....... 'grid__letters'
					   				NEXT x += gg+1
					   			;
					   			NEXT y += (gg+1)*10
					   		;
					   		gd_y = ((src.Height*1.0/gg).Int - 1) * (gg+1) + gg*0.7
					   		FOR x IN [-1 TO src.Width-1] :
					   		    LIKE ....... 'grid__letters'
					   		    NEXT x += gg+1
					   		;
					   ;
				  }
        	 ;
        	 }
        ELSE 
             NONE = hint_a(Satellite_num.Current, TRUE)
        	 {Geometry}.{rect} source|_rectangle_on_screen
        	 source.Loc = Client_pos.Offset(
        	 	0, Satellite_num.Bounds.Top)
        
        	 bmp = New_bitmap(Client_width.Points_to_pixels, 
        	 	(LabelHint1.Bounds.Bottom - Satellite_num.Bounds.Top
        	 	).Points_to_pixels, 32)
        	 	
        	 bmp = draw_to(bmp)
        ;
        CASE Key.Shift ? 
             CASE save_scr == "" ? 
                  CASE !Dialog_save_scr.Select_file ? ==> ;
                  save_scr = Dialog_save_scr.File_name
             ELSE save_scr = next_name(_) ;
             {Png}.To_file(bmp, save_scr, 100)
        ELSE NONE = bmp.To_clipboard 
        	 save_scr = "" ;
        
    ["BACK_DIRECTION"]:
        Period_rot.Set_text((-Period_rot.Text.Real).S)
    ["LOAD_UNDER_IMAGE"]:
        CASE Locked_images ? ==> ;
    	Main_.Scaled_image = NONE
    	CASE Images_path != "" ? 
    	     Dialog_image.Initial_path = Images_path ;
        CASE !Dialog_image.Select_file ? 
             CASE Main_.All_images[].Count==0 ? ==> ;
             CASE !ask("Remove all images?"._Remove_all_img) ? ==> ;
             Main_.Clear_images
             Thumbnails.Invalidate_all
             Main_.Invalidate ==> ;
        Images_path = Dialog_image.Filename.Extract_path
        Main_.Save_current_image(TRUE)
        STR f|ilename = Dialog_image.Filename  
        INT ch|ecksum = Calculate_checksum(f)
        INT ch2|ecksum = Calculate_checksum2(f)
        DEBUG:
        	CASE ch==0 ? 
        	     << "could not clalculate checksum!" #NL ;
        ;
        STR format|_actual = Actual_format(f)
        CASE format ? 
        [".png"]: Main_.Image = {Png}.From_file(f, 'FULL')
        [".bmp"]: .. = {Bmp}.From_file(f)
        [".gif"]: .. = {Gif}.Load(Path= f).Bitmap
        [".jpg", ".jpeg", ".jpe"]: .. = {Jpeg}.From_file(f, 'FULL')
        [".tif", ".tiff"]: .. = {Tiff}.From_file(f) 
        [".webp"]: .. = {WebP}.From_file(f) 
        	CASE Main_.Image.Width==0 ? 
        	     message("To open WEBP images format properly the libwebp64.dll"
        	     " should be available either via the system Path environment "
        	     "variable or placed in the same directpry where the "
        	     "GalaxyModel.exe is located. You can freely obtain it with "
        	     "some 3rd party applications or seoarately. PLEASE DON'T "
        	     "DOWNLOAD this file from arbitrary and unverified sources, "
        	     "malware is often distributed under the guise of this dll. ") ;
        ;
        //DEBUG: "loaded: =" Main_.Image.Width " x " .Height #NL ;
        ------------------- 'loaded image'
        Main_.Update_caption(f.Extract_file_name)
        Main_.Checksums_of_images[.Current_image] = ch
        Main_.Checksums2_of_images[.Current_image] = ch2
        CASE Main_.Image.Width * .Height > 13_000_000 ? 
             CASE ask("Image size (" Main_.Image.Width.S 
                  " x " Main_.Image.Height.S ") is very big. "
                  "Downscale it to fit 10M pixels ?"
                  ) 
                  ?
                  FOR r IN [2 TO Main_.Image.Width] :
                      CASE Main_.Image.Width * .Height / r / r <= 10_000_000 ? 
                           Main_.Image = Downscale(_, r)
                           BREAK r ;
                  ;
             ;
        ;
        DEBUG:
              FOR i IN [0 TO Main_.All_images[].Count-1] :
                  << i.S #TAB 
                  << Main_.All_img_names[i] #TAB 
                  << Main_.Checksums_of_images[i].Hex(8) #TAB 
                  << Main_.Checksums2_of_images[i].Hex(8) #NL 
              ;
              ;
        Main_.Invalidate
        button_colors
        Thumbnails.Invalidate_all
        CASE Url_loaded != "" ? 
             CASE !ask("Assign the URL stored with the model to the image "
                  "just loaded?"#NL Url_loaded) 
                  ? 
                  Url_loaded = "" ==> ;
             Main_.All_img_URLs[.Current_image] = Url_loaded
             Url_loaded = ""
        ;
        Auto_stamp
    ["OP_IMAGE"]:
        CASE Locked_images ? ==> ;
        Thumbnails.Invalidate_all     
        //DEBUG: << Op_image.Current ": " Main_.Current_image #NL ;
        CASE Op_image.Current ? 
        ["Prev"]:
		      CASE Main_.Current_image > 0 ? 
		           Exchange_img(Main_.Current_image-1)
		           Go_to_prev_image ==>
		      ELSE ==> ;
        ["Next"]:
		 	  CASE Main_.Current_image < Main_.All_images[].Count-1 ?
		           Exchange_img(Main_.Current_image)
		 	       Go_to_next_image ==>
		 	  ELSE ==> ;
        ["Delete"]:
            CASE Key.Control ? 
                 Main_.Protected_img = Main_.Current_image 
                 message("Images from this and above are protected!"
                 		 ""._Protected) ==>
            ;
            CASE Main_.Current_image >= Main_.Protected_img >= 0 ? 
                 CASE !ask("Image is protected. Remove protection and delete?"
                      ""._Remove_protection) ? ==> 
                 ;
                 Main_.Protected_img = -1 ;     
            Delete_current_image 
            DEBUG: "Holder[]:" Stamp_parameters.Holder.Count
            	" Checksums: " Main_.Checksums_of_images[].Merge(",")
            	" Ch2: " Main_.Checksums2_of_images[].Merge(",") 
            	#NL ;
            ==>
        ["Dup"]:
            CASE Main_.All_images[].Count==0 ? ==> ;
            Main_.Save_current_image(TRUE) 
            Main_.Update_caption(Main_.All_img_names[.Current_image]
              "" if(.All_img_URLs[.Current_image] != "",
              " URL: " .All_img_URLs[.Current_image]))
              
            CASE Key.Control ? 
                 Main_.All_images[.Current_image] = Main_.Image.Inverse_colors
                 Main_.All_scaled[.Current_image] = NONE
                 Go_to_another_image
                 CASE Main_.Protected_img >= 0 ? 
                      Main_.Protected_img += 1 ;
                 ;
        	------------------------
            DEBUG: "Holder[]:" Stamp_parameters.Holder.Count 
            		" Checksums: " Main_.Checksums_of_images[].Merge(",")
            		" Ch2: " Main_.Checksums2_of_images[].Merge(",") #NL ;
            ==>
        ["Stamp"]:
            Provide_stamp_param
        	Stamp_param.Show
            DEBUG: "Holder[]:" Stamp_parameters.Holder.Count 
            		" Checksums: " Main_.Checksums_of_images[].Merge(",")
            		" Ch2: " Main_.Checksums2_of_images[].Merge(",") #NL ;
            ==>
        ;
        Go_to_another_image
    ["ADD_SPIRAL"]:
        CASE Add_spiral.Current ? 
        ["Add"]:
	        {satellite_param} s|piral_selected 
	        NONE = Satellite_num.Add_item((All_satellites[].Count+1).S)
	        PUSH setting_spiral = TRUE :
		         s = All_satellites[Satellite_num.Current].CLONE
	        	 CASE Key.Shift ? 
	        		  All_satellites[].Insert(Satellite_num.Current+1, s.CLONE)     
	        	 ELSE All_satellites[] << s.CLONE ;
	        ;
        	CASE Key.Shift ? 
        	     Satellite_num.Select(.Current+1)
        	ELSE Satellite_num.Select(.Count-1)
        		 s.Name = ""
        		 Edit_name.Set_text("")
        		 All_satellites[*] = s.CLONE 
        	;
	        Main_.Rescale
	        Main_.Invalidate
        ELSE 
        	------------------ 'menu spirals'
        	popup_menu(

	""	Item(	"DEL_SPIRAL",
				"Delete spiral"._Del_spiral
		).Disabled(
		Satellite_num.Count <= 1
		)

	""	Item(	"DEL_RIGHT",
				"Delete from this satellite to the end"
		).Disabled(
		Satellite_num.Count <= 1
		)

	""	Item(	"MOVE_UP",
				"Move up"._Move_up
		).Disabled(
		Satellite_num.Current <= 0
		)

	""	Item(	"MOVE_DOWN",
				"Move down"._Move_dn
		).Disabled(
		Satellite_num.Current >= .Count-1
		)

	""	Item(	"",
				"Move after..."
		)

	""	Begin

	""	Custom(After_satellite)

	""	End

	""	Separator

	""	Item(	"ALL_CENTERS_HERE",
				"Move all centers of spiral after current satellite here"
		)

	""	Item(	"COPY_CENTER",
				"Copy current satellite center"
		)

	""	Item(	"PASTE_CENTER",
				"Use copied center as the spiral center"
		))



        ;
	["ADD_TO_ACTIVITY"]:
        //DEBUG: "ADD_TO_ACTIVITY clicked"#NL ;
		REAL p|eriod_rotation = Period_rot.Text.Real.Abs
		REAL mul|tiplayer = 1
		CASE Key.Shift ? mul = 0.05 ;
    	CASE Add_to_activity.Current ? 
    	["Inc"]:
    		Activity_time.Set_text((.Text.Real + p * mul).S)    
    	["Dec"]: 
    		CASE Activity_time.Text.Real > Period_rot.Text.Real ? 
    			 mul = 1
    			 CASE Key.Shift ? mul = 0.1 ;
    		     Activity_time.Set_text((.Text.Real - p * mul).S)
    		;
    	;
    	CASE Key.Control ?
    	     FOR sat IN All_satellites[] :
    	         CASE sat.INDEX == Satellite_num.Current ? 
    	              CONTINUE sat ;
    	         CASE Add_to_activity.Current ?
    	         ["Inc"]: sat.Activity += p * mul
    	         ["Dec"]: sat.Activity -= p * mul ;
    	     ;
    	;

    ["SAVE_LOAD"]:
        CASE Save_load.Current ? 
        ["Save"]:
            CASE Transform_model.Visible 
                 && (Transform_model.Rotation.Text != "" 
                 	|| Transform_model.Scaleing.Text !IN ["", "100"]
                 	|| !((Transform_model.X_offset-0.5)*(.Y_offset-0.5)).Near(0)) 
                 	?
                    //DEBUG: "Rot=" Transform_model.Rotation.Text
                    //    " Scale=" Transform_model.Scaleing.Text
                    //    " X=" Transform_model.X_offset
                    //    " Y=" Transform_model.Y_offset ;
                 	message("Transformations did not applied. Either apply "
                 	"them first or close Trasform model window.") ==> ;
    	    {In_file_config} c|onfiguration_temp
    		----------------------- 'select', REUSED     
    	    CASE !Dialog_file_save.Select_file ? ==> ;
    	    c = New_write_in_file_config(Dialog_file_save.Filename, "")
    	    -----------------------
    	    PUSH c.No_write = TRUE :
	    	     ----------------------- 'common parameters'
	    	     c.Set_r("Box_width", Box_width.Text.Real)
	    	     c.Set_i("Count_spirals", Satellite_num.Count)
	    	     c.Set_r("Mass_BH", Mass_BH.Text.Real)
	    	     ----------------------- '+image'
	    	     c.Set_b("Scale_rotate_spirals", Scale_rotate_spirals)
	    	     c.Set_r("Offset_x", Main_.Offset_x)	
	    	     c.Set_r("Offset_y", Main_.Offset_y)
	    	     //CASE !Scale_up_shift ? 
		    	      c.Set_r("Image_rotate", Rotate_image.Text.Real)
		    	      c.Set_r("Image_scale", Scale_image.Text.Real) //;
	    	     ----------------------- 'loop on all spirals'
	    	     FOR i IN [0 TO Satellite_num.Count-1] :
	    	         PUSH c.Section = (i+1).S :
		    	          s = All_satellites[i].CLONE
		    	          c...Set_s("Name", s.Name)
		    	           ...Set_r("Period", s.Period)
		    	           ...Set_r("Eccentricity", s.Eccentricity)
		    	           ...Set_r("Deviation", s.Deviation)
		    	           ...Set_r("Deviation_final", s.Deviation_final)
		    	           ...Set_r("Cone_a", s.Cone_a)
		    	           ...Set_r("Tilt", s.Tilt)
		    	           ...Set_r("Rotate", s.Rotate)
		    	           ...Set_r("Inclin", s.Inclin)
		    	           ...Set_r("StartA", s.StartA)
		    	           ...Set_r("SpeedK", s.SpeedK)
		    	           ...Set_r("FinalK", s.FinalK)
		    	           ...Set_r("Filter_speed", s.Filter_speed)
		    	           ...Set_r("Activity", s.Activity)
		    	           ...Set_r("First_ac", s.First_ac) 
		    	           ...Set_r("Last_act", s.Last_act) 
		    	           ...Set_r("Max_dist", s.Max_dist) 
		    	           ...Set_i("Arms_colors", s.ArmsColors)
		    	           ...Set_r("CenterX", s.Center_gal.X)
		    	           ...Set_r("CenterY", s.Center_gal.Y)
		    	           ...Set_b("LAST", i == Satellite_num.Count-1)
	    	         ;
	    	     ;
	    	     CASE Commands_s[].Count > 0 ?
	    	     	  DEBUG: "storing with commands (" Commands_s[].Count 
	    	     	  		 ")"#NL ;
	    	          FOR i IN [0 TO Main_.All_images[].Count-1] :
                          //CASE Main_.All_img_names[i].Lower.Starting("st") ? 
                          //     CONTINUE i ;
	    	              ch = Main_.Checksums_of_images[i]
	    	              ch2 = Main_.Checksums2_of_images[i]
	    	              CASE ch != 0 || ch2 != 0 ? BREAK i ;
	    	          ;
	    	          DEBUG: "checksums=" ch "," ch2 #NL ;
	    	          FOR i IN [0 TO Commands_s[].Count] :
	    	              CASE ch==0 && ch2==0 ? BREAK i ;
	    	              CASE i==0 ? 
	    	                   c.Set_s("Checksum", ch.Hex(8)) 
	    	                   c.Set_s("Checksum2", ch2.Hex(8)) 
	    	              ;
	    	              c.Set_s("Command" i.S, Commands_s[i])     
	    	          ;
	    	     ;
	    	     ----------------------- 'store URL if it is single'
	    	     STR url|_assigned = ""
	    	     FOR u IN Main_.All_img_URLs[] :
	    	     	 DEBUG: "i=" u.INDEX " u=" u " url=" url #NL ;
	    	         CASE u=="" ? CONTINUE u ;
	    	         //CASE url != u  ? INT count_u|rls += 1 ;
	    	         //CASE count_u > 1 ? BREAK u ;
	    	         url = u
	    	         BREAK u     
	    	     ;
	    	     c.Section = ""
	    	     CASE url!="" ? 
	    	          c.Set_s("URL", url) 
	    	          BOOL url_saved = TRUE
	    	     ELSE c.Set_s("URL", "");
    	    ;
    	    c.Update
    	    ------------------ 'update__caption', REUSED
    	    Label_file.Set_text(Dialog_file_save.Filename.Extract_file_name
    	    	.Change_ext(""))
    	    ------------------
    	    CASE url_saved ? 
    	         message("Saved togeher with URL: " url) ;
        ["Load"]: 
            Url_loaded = ""
        	INT was_cur|rent_spiral = Satellite_num.Current
        	LIKE .................. 'select', 
        		 BUT(_write_==>_read_), (Dialog_file_save==>Dialog_load)*2
        		 
        	//SE Dialog_file_save.Filename == "" ? 
        	     Dialog_file_save.Filename = Dialog_load.Filename //;
        	c.Section = ""
        	----------------------- 'renumber satellites sections'
        	STR sec|tions_list[]
        	c.List_subkeys(sec[])
        	FOR i IN [1 TO sec[].Count-1] :
        	    sec[i-1] = i.S ;
        	c.Rename_subkeys(sec[0 TO *])
        	----------------------- 'common:'
        	CASE !Key.Shift ? 
        	     Box_width.Set_text(c.Real("Box_width").S)
        	     Satellite_num.Clear
	        	 Main_.Offset_x = c.Real("Offset_x")
	        	 Main_.Offset_y = c.Real("Offset_y")    
	        	 Scale_rotate_spirals = c.Bool("Scale_rotate_spirals")
	        	 Fill_scale_rotate
        	     All_satellites[].Clear 
	        	 CASE c.Present("Mass_BH") ? 
	        	      Mass_BH.Set_text(c.Real("Mass_BH").S) ;
	        	 ----------------------- 'image rotate, scale'
	        	 Rotate_image.Set_text(c.Real("Image_rotate").S)
	        	 REAL i_sc|ale_image = c.Real("Image_scale")
	        	 CASE !i_sc.Near(0) ? Scale_image.Set_text(i_sc.S) ;
        	;
        	----------------------- 'load all spirals:'
        	FOR i IN [0 TO sec[].Count-1] :
        	    c.Section = (i + 1).S
        	    NONE= Satellite_num.Add_item((All_satellites[].Count+1).S)
        	    All_satellites[] << {satellite_param}(
        			Name= c.Str("Name"),
        			Period= c.Real("Period"),
        			Eccentricity= c.Real("Eccentricity")
        				+ c.Real("Excentricity"),
        			Deviation= c.Real("Deviation"),
        			Deviation_final= c.Real("Deviation_final"),
        			Cone_a= c.Real("Cone_a"),
        			Tilt= c.Real("Tilt"),
        			Rotate= c.Real("Rotate"),
        			Inclin= c.Real("Inclin"),
        			StartA= c.Real("StartA"),
        			SpeedK= c.Real("SpeedK"),
        			FinalK= c.Real("FinalK"),
        			Filter_speed= c.Real("Filter_speed"),
        			Activity= c.Real("Activity"),
        			First_ac= c.Real("First_ac"),
        			Last_act= c.Real("Last_act"),
        			Max_dist = c.Real("Max_dist"),
        			ArmsColors = c.Int("Arms_colors"),
        			Center_gal = Pt(c.Real("CenterX"), c.Real("CenterY"))
        	    	)
        	    CASE All_satellites[*].Center_gal.X.Near(0)
        	         && All_satellites[*].Center_gal.Y.Near(0)
        	         ? 
        	         All_satellites[*].Center_gal = Pt(Main_.Offset_x, .Offset_y)
        	    ;
        	    CASE c.Bool("LAST") ? BREAK i ;
        	;
        	CASE was_cur >= Satellite_num.Count ? was_cur = 0 ;
        	Satellite_num.Select(was_cur)
        	LIKE ............. 'update__caption', BUT (g_file_save==>g_load)*?
        	Main_.Invalidate     
        	Main_.Stack_undo[].Clear
        	Main_.Stack_redo[].Clear
        	------------------ 'load URL'
        	c.Section = ""
        	url = c.Str("URL")
        	CASE url != "" ? 
        	     FOR u IN Main_.All_img_URLs[] :
        	         CASE u==url ? 
        	              //url = "" 
        	              BREAK u ;
        	     ;
        	     Main_.All_img_URLs[0] = url
        	;
        	CASE url != "" 
        	     && ask("URL was found been stored with the model loaded. "
        		 " Copy it to the clipboard? "#NL url) 
        		 ? 
	        	 Url_loaded = url
	        	 Text_to_clipboard(url)
        	;
        	--------------------------- 'load comands ?'
        	Checksum_img_loaded = 0
        	Checksum2_img_loaded = 0
        	CASE c.Present("Checksum") ? 
        	     ch = c.Str("Checksum").From_hex 
        	     Checksum_img_loaded = ch ;
        	CASE c.Present("Checksum2") ? 
        	     ch2 = c.Str("Checksum2").From_hex 
        	     Checksum2_img_loaded = ch2 ;
			Provide_stamp_param
        	Commands_s[].Clear
    		FOR i IN [0 TO MAX_INT-1] :
