METHOD Provide_stamp_param :
	CASE Stamp_param==NONE ?
    	 Stamp_param = {Stamp_parameters}(Main_= Main_, Screen_=Screen_)
	; .

METHOD Auto_stamp :
	CASE Main_.All_images[].Count==1 
	     && (Checksum_img_loaded 
	     == Main_.Checksums_of_images[.Current_image]
	     || Checksum_img_loaded==0 && 0!=Checksum2_img_loaded 
	     == Main_.Checksums2_of_images[.Current_image])  
	     && Commands_s[].Count > 0
	     ?
	     DEBUG: "ch=" Checksum_img_loaded.Hex(8) "(" Checksum_img_loaded.S ")"
	       " ~ " Main_.Checksums_of_images[0 TO *].Merge(",")  #NL ;
		 CASE !ask("The image loaded is single and it is the "
		      "same as it was used to create the model loading. "
		      "Create stamp now ?"._Image_detected_ask_create_stamp) 
		      ? ==> ;
		 Stamp_param.Close
		 Stamp_param = NONE
		 Provide_stamp_param
		 Stamp_param.Show_no_activate
		 Stamp_param.Execute_commands(Commands_s[])
	; .
	
INT Checksum_img_loaded	
INT Checksum2_img_loaded	
STR Commands_s|equence[]


METHOD caption_loc|alizable ==> STR :
	= "Satellite /galaxy parameters"._CAPTION .

OVERRIDE mouse_down :
CASE processing_mouse ? ==> ;
PUSH processing_mouse = TRUE :
    Main_.lmb_down = mouse_button == 'LMB'
	CASE ?
	[sender_alias == "THUMBNAILS"] ?
		CASE mouse_button=='RMB' ?
		     ----------------------------- 'menu on thumbnail'
		     popup_menu(

	""	Item(	"SET_URL",
				"Set URL (from clipboard)"
		))



		;
		Main_.Save_current_image(FALSE)
	    FOR i IN [1 TO Main_.All_images[].Count-1] :
	        CASE mouse.Y - Thumbnails.Bounds.Top > Y_starting_thumb[i] ?
	             CONTINUE i ;
            //DEBUG: "i=" i " mouse.Y=" mouse.Y " Y_starting_thumb[]="
            //    "" Y_starting_thumb[].Merge(",") #NL ;
	        Main_.Current_image = i-1
	        Go_to_another_image 
	        Main_.Show ==>
	    ;
	    Main_.Current_image = Main_.All_images[].Count-1
	    Go_to_another_image 
	    Main_.Show ==>
	[sender_alias == "LABELHINT1"] ?
		 editing = NONE     
	 	 STR s|tring_to_get_vals = hint_a(Satellite_num.Current, TRUE)
	 	 CASE mouse.X < LabelHint1.Width/2 ? 
	 	      s = s.[0 TO s.Find("q")-1] 
	 	 ELSE s = s.After("L.Y. ") ;
	 	 Text_to_clipboard(s) ==> 
	[sender_alias == "MAKE_SCREENSHOT" && mouse_button=='RMB'] ?
		 Start_program("explorer.exe", "/e,/n,"
			 		"/select, "#QU save_scr #QU) ==> 
	[sender_alias == "LOAD_UNDER_IMAGE" && mouse_button=='RMB'] ?
		 DEBUG: "show explorer on [" Main_.All_img_names[.Current_image] 
		 "]"#NL ;
		 Start_program("explorer.exe", "/e,/n,"
			 		"/select, "#QU 
			 		"" Images_path.Trailing_slash 
			 		"" Main_.All_img_names[.Current_image] #QU) ==> 
	;
	CASE sender_alias.Starting("LABEL_") ? 
	     dragging = sender 
		 mouse_pos0 = mouse
		 is_0_360 = FALSE
		 CASE sender_alias ? 
		 ["LABEL_LINE_W"]: editing = Edit_line_w
		 	range_fr = 0.5
		 	range_to = 10     
		 ["LABEL_BOX_WIDTH"]: editing = Box_width
		 	-------------------------------- 'box__width', REUSED
		 	range_fr = editing.Text.Real / 2
		 	range_to = editing.Text.Real * 2 
		 	--------------------------------
		 ["LABEL_MAX_DIST"]: editing = Max_dist 
		     LIKE .......... 'box__width'
		     range_to = _.Max(10000)
		 ["LABEL_PERIOD"]: editing = Period_rot
		 	LIKE ...................... 'box__width'
		 ["LABEL_ECCENTRICITY"]: editing = Eccentricity
		 	range_fr = 0
		 	range_to = 0.99999
		 ["LABEL_MASS"]: editing = Mass_BH
		 	LIKE ...................... 'box__width'
		 ["LABEL_CONE_ANGLE"]: editing = Cone_angle
		 	range_fr = 0
		 	range_to = 90
		 ["LABEL_ROTATE_PROJ"]: editing = Rotate_proj
		 	-------------------------------- '0__360', REUSED
            is_0_360 = TRUE
		 	range_fr = -180 // (editing.Text.Real - 90)
		 	range_to = +180 // (editing.Text.Real + 90)
		 	--------------------------------
		 ["LABEL_INCLINATION"]: editing = Inclination
            //range_fr = -180
            //range_to = 180
		 	LIKE ........................... '0__360'
		 ["LABEL_TILT"]: editing = Edit_tilt
            //range_fr = -180
            //range_to = 180
		 	LIKE ........................... '0__360'
		 ["LABEL_STARTING_A"] : editing = Starting_angle
		 	LIKE ........................... '0__360'
		 ["LABEL_PLASMA_SPEED"]:editing = Plasma_speed
		 	range_fr = 0.001
		 	range_to = 1
		 ["LABEL_FINAL_K"]:editing = Final_plasma_speed
		 	range_fr = 0
		 	range_to = 1
		 ["LABEL_DEVIATION_ANGLE"]: editing = Deviation_angle
		    range_fr = -180
		    range_to = 180
		 ["LABEL_FINAL_DEVIATION"]: editing = Final_deviation
		    range_fr = -180
		    range_to = 180
		 ["LABEL_ACTIVITY_TIME"]: editing = Activity_time
		 	range_fr = (editing.Text.Real - Period_rot.Text.Real.Abs).Max(0)
		 	range_to = editing.Text.Real + Period_rot.Text.Real.Abs
            //DEBUG: "editing=" editing.Text.Real #NL
            //        " fr=" range_fr " to=" range_to #NL ;
		 ["LABEL_FIRST_ACTIVITY"]: editing = First_activity
		 	---------------------------------- 'activity__cut', REUSED
		 	range_fr = (editing.Text.Real / 5)
		 	range_to = (editing.Text.Real + 10000) 
		 	.. = _.Max(Activity_time.Text.Real.Min(editing.Text.Real * 2)) 
		 	-------------------------------
		 ["LABEL_LAST_ACTIVITY"]: editing = Last_activity
		 	LIKE ............................. 'activity__cut'
		 ["LABEL_ROTATEIMAGE"]:	editing = Rotate_image
		 	LIKE ........................ '0__360'
		 ["LABEL_SCALEIMAGE"]: editing = Scale_image
		 	LIKE ........................... 'box__width'
		 ["LABEL_SPEED_FILTER"]:
		    CASE mouse_button == 'RMB' ? 
		         Filtering_by_speed = !_
		    ELSE
			 	 editing = Filter_speed
			 	 range_fr = (editing.Text.Real - 0.2).Max(0)
			 	 range_to = (editing.Text.Real + 0.2).Min(1)
		    ;
		 ["LABEL_FILTER"]: Enable_filtering = !_
		 				   Timer_activate_filter.Set_active(TRUE)
		 				   need_invalidate = TRUE ==>
		 ELSE dragging = NONE ==> ;
		 -------------------------------- 'save initial values'
		 value_start = editing.Text.Real
		 start_value_period = Period_rot.Text.Real
		 start_value_plasma_speed = Plasma_speed.Text.Real
		 start_value_activity = Activity_time.Text.Real
		 start_value_box_width = Box_width.Text.Real
		 Main_.Stack_undo[] << All_satellites[Satellite_num.Current].CLONE
	; 
	down_with_shift = Key.Shift
	CASE Key.Shift ? 
	     range_fr = editing.Text.Real - (.Real - _)/5 
	     range_to = editing.Text.Real + (_ - .Real)/5
	     ;
;	.
	
BOOL Enable_filtering = TRUE
BOOL Filtering_by_speed = TRUE

{Label} dragging|_label_left_right
{Edit} editing|_control
REAL value_start|_editing
REAL range_fr|om
REAL range_to
BOOL is_0_360|_degrees_rotation
{point} mouse_pos0|ition_start_dragging

REAL start_value_plasma_speed
REAL start_value_period
REAL start_value_activity
REAL start_value_box_width
BOOL down_with_shift

BOOL processing_mouse


OVERRIDE mouse_move :
CASE processing_mouse ? ==> ;
PUSH processing_mouse = TRUE :
    CASE dragging==NONE || !Main_.Global_L_button ? ==> ;
	BOOL neg|ative = value_start < 0 
		 .. &&= Deviation_angle != editing != Inclination
		 .. &&= Final_deviation != editing
	BOOL is_m180_180 = range_fr.Near(-180) && range_to.Near(180)
	CASE neg && !is_m180_180 ?
		 CASE mouse.X < mouse_pos0.X ? 
			  REAL new_val|ue = value_start.Abs
			  - (value_start.Abs - range_fr.Abs) * (mouse_pos0.X - mouse.X) 
			 							 / (mouse_pos0.X - dragging.Bounds.Left)
		 ELSE new_val = value_start.Abs 
			  + (range_to.Abs - value_start.Abs) * (mouse.X - mouse_pos0.X)
			 							 / (dragging.Bounds.Right - mouse_pos0.X)
		 ;
		 CASE ?
		 [new_val < range_fr.Abs] ? new_val = range_fr.Abs 
		 [new_val > range_to.Abs] ? new_val = range_to.Abs ;
		 new_val = -_
	ELSE
	     REAL vs|tart_value = value_start
	     //BOOL is_0_360 = range_fr.Near(0) && range_to.Near(360)
		       
		 CASE mouse.X < mouse_pos0.X ? 
		      CASE ?
              //[is_0_360 && vs <= 0] ?
              //    DEBUG: "correct vs: " vs " to " (vs+360) #NL ;
              //    vs += 360
		      [is_m180_180 && vs.Near(-180)] ? vs = 180 ;
			  new_val = vs
			  - (vs - range_fr) * (mouse_pos0.X - mouse.X) 
			  					/ (mouse_pos0.X - dragging.Bounds.Left)
		 ELSE 
		      CASE ?
              //[is_0_360 && vs >= 360] ?
              //    DEBUG: "correct vs: " vs " to " (vs-360) #NL ;
              //    vs -= 360
		      [is_m180_180 && vs.Near(180)] ? vs = -180 ;
		 	  new_val = vs 
			  + (range_to - vs) * (mouse.X - mouse_pos0.X)
			  					/ (dragging.Bounds.Right - mouse_pos0.X)
		 ;
		 CASE ?
		 [new_val < range_fr] ? new_val = range_fr 
		 [new_val > range_to] ? new_val = range_to ;
	;
	PUSH sender_ = editing :
		 CASE ?
		 [!down_with_shift] ?
		      CASE ?
		      [editing == Edit_line_w] ?
		           new_val = (_ * 10).Int / 10.0
		      [Final_plasma_speed == editing || editing == Plasma_speed] ?
		           new_val = (_ * 1000).Int / 1000.0 
		      [editing == Eccentricity || editing == Filter_speed] ?
		           new_val = (_ * 10_000).Int / 10_000.0
		      ELSE new_val = _.Int ;
		 ;
	     CASE editing == Rotate_proj ?
	          CASE new_val > 180 ? new_val = new_val - 360 ;
	          CASE Rotate_together ?
		           REAL diff|erence = new_val - editing.Text.Real
		           FOR a IN All_satellites[] :
		          	   CASE a.INDEX == Satellite_num.Current ? CONTINUE a ;
		               a.Rotate += diff 
		          	   All_satellites[a.INDEX] = a.CLONE    
		           ;
	          ;
	     ;
	     editing.Set_text(new_val.S)
	     CASE ?
	     [Compensate_speed && editing == Final_plasma_speed] ?
	     	  REAL k_mul|tiplayer = new_val / value_start     
	     	  CASE !k_mul.Near(0) ? 
		           REAL new_plasma_speed = start_value_plasma_speed * k_mul 
		           PUSH sender_ = Plasma_speed :
		                Plasma_speed.Set_text(new_plasma_speed.S) ;
		           REAL new_period = start_value_period / k_mul.Power(2.0/3) 
		           PUSH sender_ = Period_rot :
		                Period_rot.Set_text(new_period.S) ;

		           REAL new_activity = start_value_activity / start_value_period
		           .. = _ * new_period 
		           PUSH sender_ = Activity_time :
		                Activity_time.Set_text(new_activity.S) ;
	     	  ;
	     [Compensate_box && editing == Mass_BH] ?
	         k_mul = new_val / value_start
	         CASE !k_mul.Near(0) ? 
	              REAL new_bw|box_width 
	              = start_value_box_width * k_mul.Power(1/3.0)
	              
	              Box_width.Set_text(new_bw.Int.S) 
	         ;
	     ;
	;
	Copy_params_same_spiral
	Main_.PBox.Invalidate_all 
	Main_.Process
;	.
	
METHOD Copy_params_same_spiral :
	INT ncur|rent_satellite = Satellite_num.Current
	{satellite_param} cur_sat|ellite = All_satellites[ncur].CLONE
    FOR sat1 IN All_satellites[] :
        {satellite_param} sat|ellite_temp = sat1.CLONE
        CASE sat1.INDEX == ncur 
             || sat.Name != cur_sat.Name
             || sat.Name=="" || cur_sat.Name=="" 
             ? CONTINUE sat1 ;
        sat...Period = cur_sat.Period
        ...Eccentricity = cur_sat.Eccentricity
        ...Cone_a = cur_sat.Cone_a
        ...Tilt = cur_sat.Tilt
        ...Rotate = cur_sat.Rotate
        ...Inclin = cur_sat.Inclin
        ...StartA = cur_sat.StartA
        ...Deviation = cur_sat.Deviation
        ...Deviation_final = cur_sat.Deviation_final
        ...Activity = cur_sat.Activity
        ...Center_gal = cur_sat.Center_gal.CLONE
        All_satellites[sat1.INDEX] = sat.CLONE
    ; .
	     
INT hint_n|umber

METHOD Change_hint :
	hint_n = (_ + 1) % 19
    //DEBUG: "set hint #" hint_n #NL ;
	CASE hint_n ? 
	[0]: 
	  LabelHint1...Set_text("Hint: drag center of spiral to the galaxy center"._H)
	[1]:...Set_text("Hint: drag over label above to change value"._H1)
	[2]:...Set_text("Hint: drag with SHIFT pressed to change value smoothly"._H2)
	[3]:...Set_text("Hint: drag on 4 edges of the main view box to change shown "
		"values"._H3)
		
	[4]:...Set_text("Hint: press SHIFT or ALT to view a distance from the "
		"center in the projection plane"._H4)
		
	[5]: ...Set_text("Hint: Ctrl+Screenshot! button screenshots this window"._H5)
	[6]: ...Set_text("Hint: Ctrl+Z/Shift+Ctrl+Z to undo/redo one change"._H6)
	[7]: ...Set_text("Hint: Click on hint left/right side to copy a/q values"._H7)
	[8]: ...Set_text("Hint: Click on period value to show a&q values in hint"._H8)
	[9]: ...Set_text("Hint: type N1-N2 or list of Nums space separated"._H9)
	[10]: ...Set_text("Hint: use also names in filters instead of numbers"._H10)
	[11]: ...Set_text("Hint: * in filters refers to a current satellite"._H11)
	[12]: ...Set_text("Hint: drag with RMB in box to fly/reset camera"._H12)
	[13]: ...Set_text("Hint: drag with Shift+RMB in box to fly/reset camera "
			"along only X or Y axis"._H13)
			
	[14]: ...Set_text("Hint: click on hint to copy a / q values"._H14)
	[15]: ...Set_text("Hint: Control+mouse_wheel to switch between last loaded "
			"images"._H15)
			
	[16]: ...Set_text("Hint: When in <Scale Up Shift All> magnifier mode, "
		    "drag with LMB from a center to move both a model and an image"._H16)

	[17]: ...Set_text("Hint: mouse_wheel to switch between satellites"._H17)
	[18]: ...Set_text("Hint: press Screenshot button with SHIFT to save a "
			"sequence of frames to a directory"._H18)
	; .

OVERRIDE mouse_up :
CASE processing_mouse ? ==> ;
PUSH processing_mouse = TRUE :
    CASE editing != NONE ?
	         REAL new_val|ue = editing.Text.Real
			 CASE is_0_360 ? 
			      CASE new_val >= 180 ? new_val -= 360 ;
			      CASE new_val < -180 ? new_val += 360 ;
			      editing.Set_text(new_val.Int.S)
			 ;
	    ;
	dragging = NONE 
	need_invalidate = TRUE
	Main_.lmb_down = FALSE
	CASE sender_alias IN ["LABELHINT1", "PERIOD_ROT", "Eccentricity", "MASS_BH"] ? 
	     NONE = hint_a(Satellite_num.Current, TRUE)
	     editing = NONE
	ELSE Change_hint ;
	button_colors ; .
	
METHOD copy_to_table :
    STR t|able_result[] << "Parameter \ Satellite"
    ..[] << "Period" << "e" << "v1" << "v2" << "d1" << "d2" << "cone"
    ..[] << "Rot projection" << "Inclination" << "Starting angle"
    ..[] << "a" << "q"
    STR filter|_sat[]
    Main_.Get_filters(filter[], Filter_sat.Text)
    FOR sat IN All_satellites[] :
        CASE Enable_filtering && (sat.INDEX+1).S !IN filter[] ? 
             CONTINUE sat ;
        CASE sat.Name != "" ? 
             t[0] = _ #TAB sat.Name
        ELSE t[0] = _ #TAB (sat.INDEX+1).S ;
        t[1] = _ #TAB sat.Period.S
        t[2] = _ #TAB sat.Eccentricity.S
        t[3] = _ #TAB sat.SpeedK.S
        t[4] = _ #TAB sat.FinalK.S
        -------------------------- '2'
        t[5] = _ #TAB sat.Deviation.S
        t[6] = _ #TAB sat.Deviation_final.S
        t[7] = _ #TAB sat.Cone_a.S
        t[8] = _ #TAB sat.Rotate.S
        t[9] = _ #TAB sat.Inclin.S
        t[10] = _ #TAB sat.StartA.S
        --------------------------- '3'
        STR s|tring_a_q = hint_a(sat.INDEX, FALSE)
        //DEBUG: "s=" s #NL ;
        STR q|_value_only = s.After("q =")
        q = q[0 TO q.Find("L.Y.")-1].Trim
        s = s.[0 TO s.Find("q =")-1].After("a =").Trim
        s = s.Remove_ending("L.Y.").Trim
        t[11] = _ #TAB s 
        t[12] = _ #TAB q 
        //DEBUG:"s=" s " q=" q #NL ;
    ;
    FOR tt IN t[] :
        STR lines|_all << tt #NL ;
    lines.Text_to_clipboard .
    
METHOD paste_from_table :
    STR lines|_all = Text_from_clipboard
    STR t|able_result[].Split(lines, #NL)
    STR list_sat|ellites[].Split(t[0], #TAB)
    CASE list_sat[0] <> "Parameter \ Satellite" ? ==> ;
    //DEBUG: "PASTING!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!"#NL ;
    --------------------------------------- 'parse 1'     
    STR pe|riods_list[].Split(t[1], #TAB)
    STR ex|centrisits[].Split(t[2], #TAB)
    STR sK|_speeds_1[].Split(t[3], #TAB)
    STR fK|_final_speeds[].Split(t[4], #TAB)
    STR d1|_deviations[].Split(t[5], #TAB)       
    STR d2|_deviations[].Split(t[6], #TAB)       
    --------------------------------------- 'parse 2'
    STR co|nes_list[].Split(t[7], #TAB)       
    STR ro|tates_list[].Split(t[8], #TAB)       
    STR in|clines_list[].Split(t[9], #TAB)
    STR st|artes_list[].Split(t[10], #TAB)
    PUSH setting_spiral = TRUE :
    	FOR n IN [1 TO list_sat[].Count-1] :
    	    INT i_sat|ellite = list_sat[n].Int - 1 
    		{satellite_param} sp|arameters = All_satellites[i_sat].CLONE
    		sp.Period = pe[n].Real
    		sp.Eccentricity = ex[n].Real
    		sp.SpeedK = sK[n].Real
    		sp.FinalK = fK[n].Real
    		------------------------ 'values 2'    
    		sp.Deviation = d1[n].Real
    		sp.Deviation_final = d2[n].Real
    		sp.Cone_a = co[n].Real
    		sp.Rotate = ro[n].Real
    		sp.Inclin = in[n].Real
    		sp.StartA = st[n].Real
    		All_satellites[i_sat] = sp.CLONE
            //DEBUG: "set satellite " i_sat " sp.Inclin=" sp.Inclin #NL ;
    	;
    ;
    ------------------------- 'finish'
    selected_satellite
    need_invalidate = TRUE
    Main_.Invalidate .
    
BOOL Use_bitmaps_24 = TRUE
{point} Center_copied

{Transform_model} Transform_model

METHOD Show_transform_model :
	CASE Transform_model == NONE ? 
	     Transform_model = {Transform_model}(Main_= Main_, Screen_=Screen_)
	;
	Transform_model.Show .


OVERRIDE menu_item :
    CASE menu_alias ?
    ["TRANSORM_MODEL"]: Show_transform_model
    ["SET_URL"]: STR url|_to_set = Text_from_clipboard
    		CASE !url.Lower.Starting("http")
    		     && !url.Lower.Starting("ftp")
    		     || ":" !IN url?
    		     message("URL must start from 'http' or 'ftp' and contain ':'!") 
    		     ==> ;
    		Main_.All_img_URLs[.Current_image] = url
    ["SCREENSHOT_1024"]: Screenshot_scale = 1024
    ["SCREENSHOT_50"]: Screenshot_scale = 50
    ["SCREENSHOT_100"]: Screenshot_scale = 100
    ["SCREENSHOT_150"]: Screenshot_scale = 150
    ["SCREENSHOT_200"]: Screenshot_scale = 200
    ["SCREENSHOT_3000"]: Screenshot_scale = 3000
    ["SCREENSHOT_1500"]: Screenshot_scale = 1500
    ["SCREENSHOT_750"]:Screenshot_scale = 750
    ["SCREENSHOT_3800"]: Screenshot_scale = 3800
    ["CROSSED_TOO"]:
        CASE Show_crossing < 1 ? Show_crossing=0 ELSE .. = 0.5 ;
    ["CROSSED_TOO_X2"]:
        CASE Show_crossing > 1 ? Show_crossing=0 ELSE .. = 2 ;
    ["CROSSED_TOO_1_1"]:
        CASE Show_crossing.Near(1) ? Show_crossing=0 ELSE .. = 1 ;
    ["SPEED_ONLY_MAIN"]: 
        CASE Show_speed != 1 ? Show_speed=1 ELSE Show_speed=0 ;
    ["SPEED_ONLY_SECOND"]:
        CASE Show_speed != 2 ? Show_speed=2 ELSE Show_speed=0 ;
    ["SAME_MAX_DIST"]: Same_max_dist = !_
    ["COPY_CENTER"]:
        Center_copied = All_satellites[Satellite_num.Current].Center_gal.CLONE
    ["PASTE_CENTER"]:
        CASE Center_copied.X.Near(0)&&Center_copied.Y.Near(0) ? NONE 
        ELSE {satellite_param} sp|aram_current 
             sp = All_satellites[Satellite_num.Current].CLONE
             sp.Center_gal = Center_copied.CLONE
             All_satellites[Satellite_num.Current] = sp.CLONE
             Main_.Offset_x = sp.Center_gal.X
             Main_.Offset_y = sp.Center_gal.Y
        ;
    ["USE_24"]: Use_bitmaps_24 = !_
    ["ALL_CENTERS_HERE"]:
        FOR sat IN All_satellites[Satellite_num.Current+1 TO *] :
            sat.Center_gal.X = Main_.Offset_x 
            sat.Center_gal.Y = Main_.Offset_y 
        	All_satellites[sat.INDEX] = sat.CLONE ;
    ["AUTO_SPEED_V1"]: Auto_final_speed = !_
    ["CTRL_TO_CHANGE"]: Control_to_change = !_
    
    ["ODD_CELLS_LINES"]: 
        CASE Cell_lines == 1 ? Cell_lines = 0 ELSE Cell_lines = 1 ;
    ["EVEN_CELLS_LINES"]:
        CASE Cell_lines == 2 ? Cell_lines = 0 ELSE Cell_lines = 2 ;
    ["NO_ORBITS"]: Draw_orbits = 0
    ["CUR_ORBIT"]: Draw_orbits = 1
    ["ALL_ORBITS"]: Draw_orbits = 2
    ["ROT_TOGETHER"]: Rotate_together = !_

    ["SAVE_POS"]:
        {Config} conf|_temp = New_write_config("PlasmaTides", 'USER', "sizes")
        FOR i IN [9 DOWNTO 1] :
            CASE !conf.Present("POS_" (i-1).S) ? CONTINUE i ;
            STR sav|ed_size = conf.Str("POS_" (i-1).S)
            conf.Set_s("POS_" i.S, sav)
        ;
        conf.Set_s("POS_0",
        Main_.Left.Points_to_pixels.S " " Main_.Top.Points_to_pixels.S 
        " " Main_.PBox.Width.Points_to_pixels.S
        " " Main_.PBox.Height.Points_to_pixels.S)
    ["COPY_TABLE"]:
        copy_to_table ==>
    ["PASTE_TABLE"]:
		paste_from_table ==>
    ["RESET"]:
        CASE !ask("All values will be set to default. Continue?"
             ""._Reset_continue) ?
             ==> ;
        FOR sp_r IN All_satellites[* DOWNTO 1] :
            All_satellites[].Delete(sp_r.INDEX) ;
        Satellite_num.Set_items("1")
        fill_combos
        LIKE after_CONSTRUCT ............. 'initial__spiral'
        Set_caption(caption_loc)
        Main_.Rescale
    ["EACH_10000_Y"]: Each_10000_years = 10000
    ["EACH_5000_Y"]:  Each_10000_years = 5000
    ["EACH_3000_Y"]:  Each_10000_years = 3000
    ["EACH_2000_Y"]:  Each_10000_years = 2000
    ["EACH_1000_Y"]:  Each_10000_years = 1000
    ["EACH_0"]:		  Each_10000_years = 0
    ["500_LY"]:		  Each_10000_years = -500
    ["1000_LY"]:	  Each_10000_years = -1000
    ["5000_LY"]:	  Each_10000_years = -5000
    ["1000_3000_LY"]: Each_10000_years = -4000
    ["DONT_DRAW_DARK"]: Dont_draw_dark = !_
    ["BRIGHT_BY_K"]: Bright_by_plasma_speed = !_
    ["GRAB_MARKERS"]: Grab_markers = !_

    ["START_PROJ_TOGETHER"]: Start_proj_together = !_
    ["COMPENSATE_SPEED_BY_PERIOD"]: Compensate_speed = !_
    ["COMPENSATE_BOXWIDTH_MASSSMBH"]: Compensate_box = !_
    	Compensate_periods = FALSE
    ["COMPENSATE_PERIODS"]: Compensate_periods = !_
    	Compensate_box = FALSE
    ["PLASMA_SPEED_ALTER"]: Alter_plasma_speed = !_    	
    ["NO_GLOVE"]: Glove = 0
    ["GLOVE_ALL"]: Glove = 1
    ["GLOVE_CUR"]: Glove = 2
    ["DARK_ALL"]: Glove = 3
    ["DARK_CUR"]: Glove = 4
    ["DARK_SHADOW"]: Glove = 5
    
    
    ["GRAB_ROT"]: Grab_rotated = !_
    
    ["DRAW_LINES"]: Draw_as = 0
    ["DRAW_DOTS"]: Draw_as = 1
    ["DRAW_DOTS_AND_LINES"]: Draw_as = -1
    
    ["AS_POLUGONS"]: Draw_as = 2
    ["AS_ZIGZAG"]: Draw_as = 3
    ["AS_ZIFZAG_5"]: Draw_as = 4
    
    ["BOTH"]: Which_spirals = 0
    ["ONE"]:  Which_spirals = 1
    ["TWO"]:  Which_spirals = 2
    ["BOTH_2ND_LIGHTENED"]: Which_spirals = 3
    ["3D_FLY_RMB"]: Rmb_3D_fly = !_
    ["CALC_DIFF"]: Calc_bright_diff = !_
    	CASE Calc_bright_diff ? 
    	     Main_.Calculations_diff = {Calculations_diff}(
    	     	Main_= Main_, Screen_= Screen_)
    	     	 
    	     Main_.Calculations_diff.Show
    	ELSE Main_.Calculations_diff = NONE ;
    ["RETROSPECTIVE"]: Retrospective = !_
    	CASE Retrospective ? Once_Retrospective = TRUE ;
    ["SCALE_ROTATE_ALL"]: Scale_rotate_spirals = !_
    	Scale_up_shift = FALSE
    	Main_.Cache_image = NONE
    	Fill_scale_rotate
    ["SCALEUP_SHIFT"]:
    	Scale_up_shift = !_
    	CASE Scale_up_shift ? Scale_rotate_spirals = FALSE ;
    	Fill_scale_rotate
    ["CONTROL_TO_DRAG_CENTER"]: Control_drag_center = !_
    ["SHOW_CONE"]: Show_cone = !_
    ["SHOW_DEVIATION"]: Show_deviations = !_
    ["UNSCALE_IMAGE"]:
        REAL si|mage_scale = 100 / Scale_image.Text.Real
        REAL ri|image_rotate = Rotate_image.Text.Real
        FOR sp_r IN All_satellites[] :
            sp_r.Period = _ * si.Power(3/2.0)
            sp_r.Activity = _ * si.Power(3/2.0)
            sp_r.Last_act = _ * si.Power(3/2.0)
            sp_r.Rotate -= ri
            All_satellites[sp_r.INDEX] = sp_r.CLONE  
        ;
        PUSH setting_spiral = TRUE :
	         Main_.All_scales[.Current_image] = 100
	         Main_.All_rotations[.Current_image] = 0
	         Scale_image.Set_text("100")
	         Rotate_image.Set_text("0")
        ;
        selected_satellite
    ["DEL_SPIRAL"]:
        CASE !ask("Spiral number " Satellite_num.Text " will be deleted."
             " Continue?") 
             ? ==> ;
        INT dn|umber_spiral_to_remove = Satellite_num.Current
        STR nn|umbers_in_combo[]
        ------------------------------- 'delete__dn', REUSED
        All_satellites[].Delete(dn)
        nn[].Clear
        FOR i IN [0 TO All_satellites[].Count-1] :
            nn[] << (i+1).S ;
        Satellite_num.Set_array(nn[])
        Satellite_num.Select(dn.Min(Satellite_num.Count-1))
        -------------------------------
    ["DEL_RIGHT"]:
        CASE !ask("Spirals from " Satellite_num.Text " yo the end will be deleted."
             " (total " (All_satellites[].Count - Satellite_num.Current).S
             "). Continue?") 
             ? ==> ;
        FOR di IN [All_satellites[].Count-1 DOWNTO Satellite_num.Current] :
            dn = di
            LIKE .................... 'delete__dn'
        ;
    ["MOVE_UP"]:
        {satellite_param} msp|_to_move 
        .. = All_satellites[Satellite_num.Current].CLONE
        All_satellites[].Delete(Satellite_num.Current)
        All_satellites[].Insert(Satellite_num.Current-1, msp)
        Satellite_num.Select(.Current-1)
    ["MOVE_DOWN"]:
        msp = All_satellites[Satellite_num.Current].CLONE
        All_satellites[].Delete(Satellite_num.Current)
        All_satellites[].Insert(Satellite_num.Current+1, msp)
        Satellite_num.Select(.Current+1)
    ELSE
    	CASE ?
    	[menu_alias.Starting("POS_")] ?
    	     conf = New_read_config("PlasmaTides", 'USER', "sizes")
    	     STR sizes_r|estore[].Split(conf.Str("POS_" menu_alias.After("_")), 
    	     	 " ")
    	
    	     Main_.Set_size(sizes_r[2].Int.Pixels_to_points
    	     			+ Main_.Width - Main_.PBox.Width, 
    	     		  sizes_r[3].Int.Pixels_to_points
    	     		    + Main_.Height - Main_.PBox.Height,
    	     		  'SIZE_AS_IS')
    	     		  
    	     Main_.Set_position(sizes_r[0].Int.Pixels_to_points,
    	     			  sizes_r[1].Int.Pixels_to_points,
    	     			  'POSITION_AS_IS')
    	[menu_alias.Starting("AFTER_")] ?
    	     INT after|_what = menu_alias.After("_").Int
    	     msp = All_satellites[Satellite_num.Current].CLONE
    	     CASE after < Satellite_num.Current ? after += 1 ;
    	     All_satellites[].Delete(Satellite_num.Current)
    	     All_satellites[].Insert(after, msp)
    	     Satellite_num.Select(after)
    	;
    ; 
    need_invalidate = TRUE
    Main_.Invalidate 
    ------------------------- 'save options'
    conf = New_write_config("Multi-spiral-model", 'USER', "")
    conf.Set_i("SCREENSHOT_SCALE", Screenshot_scale)
    conf.Set_r("LINE_WIDTH", Edit_line_w.Text.Real)
    conf.Set_i("TRANSPARENCY", Transparency_sel.Current)
    .
    
    


OVERRIDE timer :
    CASE sender_alias ?
    ["TIMER_ACTIVATE_FILTER"]:
    	 sender.{Timer}.Set_active(FALSE)
    	 Set_active(Filter_sat)
    ["TIMER_INVALIDATE"]:
        CASE need_invalidate ?
             need_invalidate = FALSE
             Main_.Invalidate ;
    ELSE BASE ; .
    
    
    

OVERRIDE key_down ==> {Form}.{action} :
	CASE Key.Control ?
	     CASE Key.Special ?
	     [LETTER_Z]: 
	         CASE Key.Shift ? Redo ELSE Undo ; 
	     [LETTER_T]:
	     	 CASE !Transform_model.Visible ? Show_transform_model ;
	     ;
	ELSE
		 CASE Key.Special ? 
		 [F_5]: copy_to_table 
		 [F_6]: paste_from_table
		 ;
	; .
	     
	     
METHOD Undo|_one_change :
	CASE Main_.Stack_undo[].Count == 0 ? ==> ;
    All_satellites[Satellite_num.Current] = Main_.Stack_undo[*].CLONE 
    Main_.Stack_redo[] << Main_.Stack_undo[*].CLONE
    Main_.Stack_undo[].Delete(Main_.Stack_undo[].Count-1)
    selected_satellite
    need_invalidate = TRUE .
    
METHOD Redo|_one_change :
    CASE Main_.Stack_redo[].Count == 0 ? ==> ;
    All_satellites[Satellite_num.Current] = Main_.Stack_redo[*].CLONE 
    Main_.Stack_undo[] << Main_.Stack_redo[*].CLONE
    Main_.Stack_redo[].Delete(Main_.Stack_redo[].Count-1)
    selected_satellite
    need_invalidate = TRUE .
    
METHOD draw_to|_bitmap(
{Bitmap} to|_bitmap) ==> {Bitmap}, NEW
    :
	{Canvas} c|anvas_destination = to.Canvas
    c.Background = SILVER
    c.Erase
    c.Background = WHITE
    c.Font.Size = 12
    {Control} contr|ols_to_draw[] << LabelSelectSpiral << Satellite_num
    CASE Edit_name.Text != "" ? 
         ..[] << LabelName << Edit_name ;
    ..[] << Label_period << Period_rot
    ..[] << Label_Eccentricity << Eccentricity
    ..[] << Label_Mass << Mass_BH
    ..[] << Label_plasma_speed<<Plasma_speed <<Label_final_k<<Final_plasma_speed
    ..[] << Label_deviation_angle << Deviation_angle 
    ..[] << Label_final_deviation << Final_deviation
    ..[] << Label_cone_angle << Cone_angle
    ..[] << Label_rotate_proj << Rotate_proj
    ..[] << Label_inclination << Inclination
    ..[] << Label_starting_a << Starting_angle
    ..[] << Label_activity_time << Activity_time
    CASE First_activity.Text.Real > 0 ? 
         ..[] << Label_first_activity << First_activity ;
    CASE Last_activity.Text.Real > 0 ? 
         ..[] << Label_last_activity << Last_activity ;
    ..[] << LabelHint1
    ------------------------------- 'draw all controls'
    REAL y|_position = 0
    FOR con IN contr[] :
        {rect} b|ounds_dest = con.Bounds.Offset(0,-Satellite_num.Bounds.Top)
        b.Loc.Y = y
        b.Height = 16
        CASE con.{Label}==NONE ? 
             c.Rect(b) 
             REAL offset_x = 4
             y += b.Height + 1
        ELSE offset_x = c.Measure(con.Text).W
        	 offset_x = b.Width - 4 - _
        ;
        c.Text(b.Loc.Offset(2 + offset_x, 2), con.Text)     
    ;
    RESULT = New_bitmap(to.Width, y.Points_to_pixels, 32)
    to.Draw(RESULT.Canvas, Pt(0, 0))
    .
	     

OVERRIDE disabled ==> BOOL :
    CASE sender_alias ?
    ["MAKE_SCREENSHOT", "LOAD_UNDER_IMAGE"]: RESULT = Locked_images
    //["DEL_IMAGE"]: RESULT = Main_.All_images[].Count <= 1
    ["OP_IMAGE"]: 
        RESULT = Locked_images 
        || Main_.All_images[].Count <= 0 && Main_.Image==NONE
        
    ["FILTER_SPEED"]: RESULT = !Filtering_by_speed
    ["FILTER_SAT"]: RESULT = !Enable_filtering
    ; .
    
   
BOOL last_hidden_dev|iation
BOOL last_hidden_cone
//BOOL use_last_hidden|_cone_and_deviation

OVERRIDE hidden ==> BOOL :
    CASE sender_alias ?
    ["LABEL_FINAL_K", "FINAL_PLASMA_SPEED"]:
    	RESULT = !Show_deviations && Final_plasma_speed.Text.Real.Near(0)
    ["LABEL_DEVIATION_ANGLE", "DEVIATION_ANGLE", 
     "LABEL_FINAL_DEVIATION", "FINAL_DEVIATION"]:
        //CASE use_last_hidden || setting_spiral ? 
        CASE setting_spiral ? 
             RESULT = last_hidden_dev ==> ;
        RESULT = !Show_deviations && (
        	Deviation_angle.Text==Final_deviation.Text
        	|| Final_deviation.Text=="")
        last_hidden_dev = RESULT
    ["LABEL_CONE_ANGLE", "CONE_ANGLE"]: 
        //CASE use_last_hidden || setting_spiral ? 
        CASE setting_spiral ? 
             RESULT = last_hidden_cone ==> ;
        RESULT = !Show_cone && Cone_angle.Text.Real >= 90
        last_hidden_cone = RESULT
    ; .
    
{Stamp_parameters} Stamp_param|eters

METHOD Go_to_prev_image :
	Main_.Save_current_image(FALSE)
	CASE Main_.Current_image <= 0 ? ==> ;
	Main_.Current_image -= 1
	----------------------------- 'update__caption', REUSED
	Main_.Update_caption(.All_img_names[.Current_image]
	  "" if(.All_img_URLs[.Current_image] != "", 
	  " URL: " .All_img_URLs[.Current_image]))
	-----------------------------
	Go_to_another_image . 
	
METHOD Go_to_next_image :
    Main_.Save_current_image(FALSE)
    CASE Main_.Current_image >= Main_.All_images[].Count-1 ? ==> ;
    Main_.Current_image += 1
    LIKE Go_to_prev_image ............ 'update__caption'
	Go_to_another_image . 

METHOD Go_to_another_image :
	-------------------------- 'go to another image'
	Main_.Image = Main_.All_images[.Current_image]
	Main_.Scaled_image = Main_.All_scaled[.Current_image]
    LIKE Go_to_prev_image ............ 'update__caption'
	Main_.Invalidate
    //DEBUG: ">>> " Main_.Current_image #NL ;
    Thumbnails.Invalidate_all
    .
    
METHOD Delete_current_image :
    INT ci|image_current = Main_.Current_image
    {Bitmap} b_d|eleting = Main_.All_images[ci]
    Stamp_parameters.Holder.Delete(b_d)
    b_d = NONE
    ---------------------------------
    Main_.All_images[].Delete(ci)
	Main_.All_scaled[].Delete(ci)
	--------------------------------- 'and attributes'
    Main_.Checksums_of_images[].Delete(ci)
    Main_.Checksums2_of_images[].Delete(ci)
	Main_.All_img_names[].Delete(ci)
	Main_.All_img_URLs[].Delete(ci)
	Main_.All_scales[].Delete(ci)
	Main_.All_rotations[].Delete(ci)
	CASE ci >= Main_.All_images[].Count ? 
	     Main_.Current_image -= 1 ;
	--------------------------- 
	Go_to_another_image .
	
METHOD Exchange_img(INT From|_image) :
    CASE From >= Main_.All_images[].Count ? ==> ;
    Main_.Save_current_image(FALSE)
    ------------------------------------------------ 'exchange'     
    {Bitmap} temp|_image = Main_.All_images[From]
    Main_.All_images[From] = Main_.All_images[From+1]
    Main_.All_images[From+1] = temp
    STR s_temp|_name
    ------------------------------------------------- 'xchg__s', REUSED
    s_temp = Main_.All_img_names[From]
    Main_.All_img_names[From] = Main_.All_img_names[From+1]
    Main_.All_img_names[From+1] = s_temp
    ------------------------------------------------
    LIKE .......... 'xchg__s', BUT(img_names==>img_URLs)*4
    ------------------------------------------------ 'update current'
    Main_.Image = Main_.All_images[.Current_image]
    Go_to_another_image .
	
BOOL Locked_images|_working
REAL Y_starting_thumb|nails[]
    

OVERRIDE paint :
    CASE sender_alias ?
    ["PAINTBOX_1"]: NONE
    ["THUMBNAILS"]:
        {Canvas} c|anves_dest = Thumbnails.Canvas
        c.Erase
        c.Quality = 'LOW'
        REAL h|eight|_of_thumbnail 
        h = (Thumbnails.Height / (Main_.All_images[].Count+1)).Max(40)
        REAL y|_top_pos = 1
        FOR i IN [0 TO Main_.All_images[].Count-1] :
            CASE Y_starting_thumb[].Count <= i ? 
                 Y_starting_thumb[] << y
            ELSE Y_starting_thumb[i] = y ;
        	CASE Main_.Current_image==i ? 
        	     REAL cur_h|eight = Main_.Image.Height
        	ELSE cur_h = Main_.All_images[i].Height ;
            {rect} dest|ination = {rect}(Loc=Pt(2,y), W=Thumbnails.Width-4, 
            	H=h.Min(cur_h/10+10))
            --------------- 'draw image'
            CASE i == Main_.Current_image ? 
            	 PUSH c.Foreground = RED :
            	      c.Pen_width = 5
            	      c.Rect(dest.Inflate(2, 2)) ;
                 {Bitmap} b|itmap_thuming = Main_.Image 
            ELSE b = Main_.All_images[i] ;
            b.Stretch_draw(c, dest)
            ----------------- 'draw size'
            PUSH c.Foreground = BLACK :
            PUSH c.Quality = 'HIGH' :
                 FOR dd IN [1 DOWNTO 0] :
                     c.Text(Pt(2 + dd.Pixels_to_points, 
                     		   y+1 + dd.Pixels_to_points), 
                     		b.Width.S " x " b.Height.S)

                     c.Foreground = WHITE 
                 ;
            ;
            ;
        	y += dest.H + 1    
        ;
    ELSE BASE
    ; .
    

OVERRIDE mouse_wheel ==> BOOL :
	CASE Key.Control ? 
	     CASE vertical_wheel < 0 ? 
	          font_size += 1
	     ELSE font_size = (_ - 1).Max(8) ;
	     FOR c IN Children[] :
	         CASE c.{Label} != NONE ?
	              c.Set_font_size(font_size-2)
	              STR t|ext_old = c.Text
	              //c.{Label}.Set_text(t "^")
	              c.{Label}.Set_text(t)
	              c.Set_height(font_size)
	         ELSE
	              c.Set_font_size(font_size)
	         ;
	         CASE c.{Button} != NONE || c.{Checkbox} != NONE
	              || c.{Paint_turtle} != NONE
	              ? c.Set_height(font_size+2) ;
	         ;
	     FOR col IN columns[] :
	         Do_adjust_controls(THIS, col) ;
	;
	.
	
REAL font_size = 12

METHOD no_lines_in_odd_rows({Bitmap} bmp|_to_change) :
	-------------------------- 'prepare__no__lines__bitmap', REUSED
    {Bitmap} nlb|_no_lines_bitmap_TEMP = New_bitmap(bmp.Width, .Height, 24) 
    PUSH Main_.No_lines = TRUE :
         Main_.Paint_to(nlb.Canvas, TRUE) ;
         nlb.Canvas.Units = 'PIXELS'
         nlb.Canvas.Reset_transform
         bmp.Canvas.Reset_transform
    ---------------------------------------
    {Bitmap} temp|_row = New_bitmap(bmp.Width, 100, 24)
    temp.Canvas.Units = 'PIXELS'
    PUSH bmp.Canvas.Units = 'PIXELS' :
    FOR y IN [100 TO bmp.Height-1] :
        nlb.Draw(temp.Canvas, Pt(0, -y))
        temp.Draw(bmp.Canvas, Pt(0, y))
        //DEBUG: {Png}.To_file(temp, "temp[" y.S "].png", 100)
        //        nlb.Draw(temp.Canvas, Pt(-bmp.Width/2, -y+100))
        //        PUSH temp.Canvas.Foreground = WHITE :
        //             temp.Canvas.Text(Pt(0,0), "--> " y.S) ;
        //        temp.Draw(bmp.Canvas, Pt(bmp.Width/2, y-100))    
        //;
        NEXT y += 200
    ; 
    ; .
    
METHOD no_lines_in_even_rows({Bitmap} bmp|_to_change) :
	LIKE no_lines_in_odd_rows ......... 'prepare__no__lines__bitmap'
    {Bitmap} temp|_row = New_bitmap(bmp.Width, 100, 24)
    temp.Canvas.Units = 'PIXELS'
    PUSH bmp.Canvas.Units = 'PIXELS' :
    FOR y IN [0 TO bmp.Height-1] :
        nlb.Draw(temp.Canvas, Pt(0, -y))
        temp.Draw(bmp.Canvas, Pt(0, y))
        //DEBUG: {Png}.To_file(temp, "temp[" y.S "].png", 100)
        //        nlb.Draw(temp.Canvas, Pt(-bmp.Width/2, -y+100))
        //        PUSH temp.Canvas.Foreground = WHITE :
        //             temp.Canvas.Text(Pt(0,0), "--> " y.S) ;
        //        temp.Draw(bmp.Canvas, Pt(bmp.Width/2, y-100))    
        //;
        NEXT y += 200
    ; 
    ; .
    
METHOD no_lines_in_odd_cols(
{Bitmap} bmp|_to_change)
    :
	LIKE no_lines_in_odd_rows.......... 'prepare__no__lines__bitmap'
    {Bitmap} temp|_row = New_bitmap(100, bmp.Height, 24)
    temp.Canvas.Units = 'PIXELS'
    PUSH bmp.Canvas.Units = 'PIXELS' :
    FOR x IN [100 TO bmp.Width-1] :
        nlb.Draw(temp.Canvas, Pt(-x, 0))
        temp.Draw(bmp.Canvas, Pt(x, 0))
        NEXT x += 200
    ; 
    ; .
    
METHOD no_lines_in_even_cols(
{Bitmap} bmp|_to_change)
    :
	LIKE no_lines_in_odd_rows.......... 'prepare__no__lines__bitmap'
    {Bitmap} temp|_row = New_bitmap(100, bmp.Height, 24)
    temp.Canvas.Units = 'PIXELS'
    PUSH bmp.Canvas.Units = 'PIXELS' :
    FOR x IN [0 TO bmp.Width-1] :
        nlb.Draw(temp.Canvas, Pt(-x, 0))
        temp.Draw(bmp.Canvas, Pt(x, 0))
        NEXT x += 200
    ; 
    ; .
    
METHOD double_all_rows_with_no_lines_rows(
{Bitmap} bmp|_source_bitmap) ==> {Bitmap}, NEW
    :
    RESULT = New_bitmap(bmp.Width, .Height * 2 * 101 / 100, 24)
    RESULT.Canvas...Background = WHITE
    	  		 ...Erase  
    	  		 ...Units = 'PIXELS'
	LIKE no_lines_in_odd_rows .................. 'prepare__no__lines__bitmap',
		BUT (.Height==> . Height * 201 / 200)
	{Bitmap} temp|_row = New_bitmap(bmp.Width, 100, 24)
	temp.Canvas.Units = 'PIXELS'
	PUSH bmp.Canvas.Units = 'PIXELS' :
	FOR y IN [0 TO bmp.Height-1] :
	    bmp.Draw(temp.Canvas, Pt(0, -y)) 
		temp.Draw(RESULT.Canvas, Pt(0, (y*201/100)))
		nlb.Draw(temp.Canvas, Pt(0, -y))
		temp.Draw(RESULT.Canvas, Pt(0, (y*201/100+100)))
		NEXT y += 100    
	;
    ; .
    
METHOD gradient_lines_shot(
{Bitmap} bmp|_source, INT direction, 
INT transparency|_start, INT delta_tr|ansparency) ==> {Bitmap_direct}, NEW
    :
	---------------------------------- 'save all satellites'
	FOR s IN All_satellites[] :
	    {satellite_param} save_sat[] << s.CLONE ;
	BOOL to_b|itmap_1 = TRUE
	---------------------------------- 'background image --> RESULT'
    RESULT = New_bitmap_direct(bmp.Width, .Height, 32) 
	PUSH Main_.No_lines = TRUE :
	     Main_.Paint_to(RESULT.Canvas, to_b) ;
	--------------------------------- '1st line --> alb'
	{Bitmap_direct} alb|_all_lines_only_bitmap_TEMP 
	alb = New_bitmap_direct(bmp.Width, .Height, 32)
	alb.Canvas.Background = BLACK
	alb.Canvas.Erase
    //PUSH Draw_background_image = FALSE :
    //     Main_.Paint_to(alb.Canvas, to_b) ;
	PUSH Transp = transparency :
		---------------------------- 'provide primary alb mask'
		FOR y IN [0 TO alb.Height-1] :
		    alb.Lock_rows(y, 1, TRUE)
		    INT xx|_position_in_row = 0 
			FOR x IN [0 TO alb.Width-1] :
				CASE alb.Pixels[xx]==alb.Pixels[xx+1]==alb.Pixels[xx+2]=='00' ? 
				     alb.Pixels[xx+3] = '00' 
			;
				xx += 4
			;
			alb.Unlock(TRUE)
		;
		------------------ 'create lob = lines only image'
		{Bitmap_direct} lob|_all_lines_only_bitmap_TEMP 
		lob = New_bitmap_direct(bmp.Width, .Height, 32)
		lob.Canvas.Background = BLACK
		------------------ 'create lai = lines anf image'
		{Bitmap_direct} iob|_imag_only_bitmap_TEMP
		iob = New_bitmap_direct(bmp.Width, .Height, 32)
		iob.Canvas.Background = BLACK
			Main_.Paint_to(iob.Canvas, to_b)
		
		REAL ii|_multiplier = 1.7
		FOR i IN [1 TO 10] :
			Progress_long.Set_progress(i*10)
			Long_operation.Indicate(TRUE)
			ii += 1     
			CASE direction != 0 ? 
				 ---------------------------- 'provide__transparency__mask', REUSED
             //DEBUG: "i=" i " ii=" ii " Activity=" All_satellites[0].Activity 
             //    "(" (All_satellites[0].Activity - save_sat[0].Activity) ")"
             //    " Transp=" Transp #NL ;
				 lob.Canvas.Erase
				 Main_.Paint_to(lob.Canvas, to_b)
				 FOR y IN [0 TO lob.Height-1] :
				     iob.Lock_rows(y, 1, TRUE)
				     lob.Lock_rows(y, 1, TRUE)
				     alb.Lock_rows(y, 1, TRUE)
				     xx = 0 
					 FOR x IN [0 TO lob.Width-1] :
						 CASE lob.Pixels[xx]==iob.Pixels[xx]
						      && lob.Pixels[xx+1]==iob.Pixels[xx+1]
						      && lob.Pixels[xx+2]==iob.Pixels[xx+2] 
						      || lob.Pixels[xx].Int < 10
						      && lob.Pixels[xx+1].Int < 10 
						      && lob.Pixels[xx+2].Int < 10
						      ?
						      NONE 
						 ELSE alb.Pixels[xx] = lob.Pixels[xx]
						      alb.Pixels[xx+1] = lob.Pixels[xx+1]
						      alb.Pixels[xx+2] = lob.Pixels[xx+2]
							  alb.Pixels[xx+3] = lob.Pixels[xx+3] ;
						 xx += 4
					 ;
					 lob.Unlock(FALSE)
					 iob.Unlock(FALSE)
					 alb.Unlock(TRUE)
				 ;
				 ----------------------- 'shift activity', REUSED
			;
			CASE direction != 0 ? 
			     FOR s IN All_satellites[] :
			         s.Activity += 2000 * direction
			         All_satellites[s.INDEX] = s.CLONE 
			     ;
			ELSE 
				 --------------- 'shift__activity', REUSED
			     FOR s IN All_satellites[] :
			         s.Activity = save_sat[s.INDEX].Activity -2000*ii
			         All_satellites[s.INDEX] = s.CLONE 
			     ;
			     ---------------
			     LIKE ........... 'provide__transparency__mask'
			     //LIKE ........... 'shift__activity', BUT(-2000*i+2000==>+2000*i) 
			     LIKE ........... 'shift__activity', BUT(-2000==>+2000) 
			     LIKE ........... 'provide__transparency__mask'
			;
			Transp += delta_tr
			CASE delta_tr > 0 && Transp >= 60 
			     || delta_tr < 0 && Transp < 10
			     ? BREAK i ;
		;
        //DEBUG: {Png}.To_file(alb, "alb.png", 100)
        //        {Png}.To_file(RESULT, "RESULT-before.png", 100) 
        //;
		RESULT.Canvas.Reset_transform
		alb.Draw(RESULT.Canvas, Pt(0,0))
		---------------------------------- 'restore all satellites'
		FOR s IN save_sat[] :
		    All_satellites[s.INDEX] = s.CLONE ;
		Progress_long.Set_progress(0)
	;
    .
    
METHOD line_around_of_spiral(
INT points|_wide, BOOL with_lines) 
==> {Bitmap}, NEW
    :
	{Bitmap_direct} bmp|_temp = New_bitmap_direct(
			Main_.PBox.Width.Points_to_pixels,
			Main_.PBox.Height.Points_to_pixels, 24)
			
	PUSH Main_.No_lines = TRUE : 
	     CASE with_lines ? Main_.No_lines = FALSE ;
	     Main_.Paint_to(bmp.Canvas, TRUE)
	     //DEBUG: {Png}.To_file(bmp, "before_-line-shot.png", 100) ;
	;
    RESULT = New_bitmap(bmp.Width, .Height * 2, 24) 
    RESULT.Canvas.Background = WHITE
    RESULT.Canvas.Erase
    PUSH RESULT.Canvas.Units = 'PIXELS' :
         PUSH RESULT.Canvas.Foreground = RED :
         PUSH RESULT.Canvas.Pen_width = 5 :
         RESULT.Canvas.Ellipse({rect}(
         	Loc= Pt(RESULT.Width/2 - 500, .Height/2-500), W=1000, H=1000))
         ;
         ;
    ------------------------- 'dummy bitmap'
	{Bitmap} temp|_lines_only = New_bitmap(bmp.Width, .Height, 24)
	temp.Canvas.Units = 'PIXELS'
	-------------------- 'small portion bitmap to copy a square around a point'
	{Bitmap_direct} rect|angle_TEMP = New_bitmap_direct(
		points.Points_to_pixels * 2, points.Points_to_pixels * 2, 24)
	rect.Canvas.Units = 'PIXELS'
	rect.Canvas.Quality = 'LOW'
	-------------------- 'small portion bitmap to draw rect above rotated'
	{Bitmap} rrot|ated_bitmap_temp = New_bitmap(
		points.Points_to_pixels, points.Points_to_pixels, 24)
	rrot.Canvas.Units = 'PIXELS'
		
	{point} dest|ination = Pt(RESULT.Width/2, .Height/2)
	INT direction|_drawing = +1
		
	PUSH Draw_background_image = FALSE :
	PUSH Main_.Store_dots = TRUE :
	PUSH Which_spirals = 1 :
	     {point} src|_point
	     {point} next|_point
	     {point} vec|tor_direction
	     REAL size|_vector
	     REAL angle|_rotation
	     BOOL use_prev|ious
	     REAL from_prog|ress = 0
	     INT total|_dots
	     ------------------------------------ 'draw__spiral__1', REUSED
	     PUSH Main_.Only_cur = TRUE :
	          Main_.Paint_to(temp.Canvas, TRUE) ;
	     use_prev = FALSE
	     total = Main_.All_dots[].Count
	     FOR i IN [total-1 DOWNTO 1] :
	     	 CASE i % 100 == 0 ? 
	     	      Progress_long.Set_progress(
	     	      	from_prog + (total - i) * 50 / total)
	     	      
	     	      Long_operation.Indicate(TRUE)
	     	 ;
	     //FOR i IN [Main_.All_dots[].Count.Min(300)-1 DOWNTO 1] :
	         CASE !use_prev ?
		          src = Pt(Main_.All_dots[i].X.Points_to_pixels,
		         		   Main_.All_dots[i].Y.Points_to_pixels)
	         ELSE use_prev = FALSE ;
	         next = Pt(Main_.All_dots[i-1].X.Points_to_pixels,
	         		   Main_.All_dots[i-1].Y.Points_to_pixels) 
	         		   
	         vec = Pt(next.X - src.X, next.Y - src.Y)
	     	 size = Sqrt(vec.X.qq + vec.Y.qq)
	     	 CASE size <= 0.001 ?
	     	      use_prev = TRUE
	     	      CONTINUE i ;
	     	 angle = Arctan2(-vec.Y/size, vec.X/size) * 180 / PI
	     	 CASE direction < 0 ? angle += 180 ;
	     	 ----------------- 'now copy next portion from bmp to RESULT'
             bmp.Draw(rect.Canvas,
                Pt(-src.X + rect.Width/2, -src.Y + rect.Height/2))
	     	 	
             //bmp.Copy_to_bitmap_direct((src.X - rect.Width/2).Int,
             //   (src.Y-rect.Height/2).Int, rect)
	     	 	
	     	 rrot.Canvas.Reset_transform
	     	 rrot.Canvas.Offset(rrot.Width*0.5, rrot.Height*0.5)
	     	 rrot.Canvas.Rotate(angle)
	     	 rrot.Canvas.Offset(-rrot.Width*0.5, -rrot.Height*0.5)
	     	 rect.Draw(rrot.Canvas, Pt(-rrot.Width/2, -rrot.Height/2))
	     	 ----------------- 'now draw rotated portions'
	     	 rrot.Canvas.Reset_transform
	     	 rrot.Draw(RESULT.Canvas, dest.Offset(-rrot.Width/2, -rrot.Height/2))
	     	 DEBUG: 
	     	 	CASE i <= 100 ? 
	     	       << "dot " i " from " Main_.All_dots[].Count
	     	 		" src=" src.Sp " vec=" vec.Sp " size=" size 
	     	 		" a=" angle #NL
	     	 	//{Png}.To_file(rect, "rect-src" (i*direction).S ".png", 100)
	     	 	//{Png}.To_file(rrot, "rect-rot" (i*direction).S ".png", 100)
	     	 	;
	     	 ;
	     	 dest.X += direction * size
	     	 CASE ?
	     	 [direction > 0 && dest.X >= RESULT.Width - size] ?
	     	      dest.X = 0 
	     	      dest.Y += rrot.Height + 2
	     	      CASE dest.Y >= RESULT.Height ? BREAK i ;
	     	      rrot.Draw(RESULT.Canvas, 
	     	      	dest.Offset(-rrot.Width/2, -rrot.Height/2))
	     	      	
	     	      dest.X += direction * size
	     	 [direction < 0 && dest.X <= 0] ?
	     	      dest.X = RESULT.Width - rrot.Width
	     	      dest.Y -= rrot.Height + 2
	     	      CASE dest.Y <= 0 ? BREAK i ;
	     	      rrot.Draw(RESULT.Canvas, 
	     	      	dest.Offset(-rrot.Width/2, -rrot.Height/2))
	     	      	
	     	      dest.X += direction * size
	     	 ;
	     ;
	     ------------------------------------
	     Which_spirals = 2
	     direction = -1
	     dest = Pt(RESULT.Width/2, .Height/2)
	     from_prog = 50
	     LIKE ................................. 'draw__spiral__1'
	     Progress_long.Set_progress(0)
	;
	;
	;
	
    ;
    .
    
    
FUN Calculate_checksum(STR Path|_of_file) ==> INT :
    {File_stream} f|ile_temp= Read_file_stream(Path) 
    BYTE buf|fer_64K[].Allocate(65536)
    RESULT = 0
    FOR i IN [0 TO f.Size.To_int/65536] :
        INT size|_read = f.Read_bytes(buf[0 TO *]) 
        FOR j IN [0 TO size-1] :
            RESULT = _.ShiftL(1) ^ buf[j].Int ;
    ;
    RESULT &= 0x7FFF_FFFF .

FUN Calculate_checksum2(STR Path|_of_file) ==> INT :
    {File_stream} f|ile_temp= Read_file_stream(Path) 
    BYTE buf|fer_64K[].Allocate(65536)
    RESULT = 0
    FOR i IN [0 TO f.Size.To_int/65536] :
        INT size|_read = f.Read_bytes(buf[0 TO *]) 
        FOR j IN [0 TO size-1] :
            RESULT = _.ShiftL(1) ^ buf[j].Int ^ (RESULT.ShiftR(31) & 1) ;
    ;
    RESULT &= 0x7FFF_FFFF .


FUN Downscale(
{Bitmap} B|itmap_to_reduce, INT K|oefficient_2_or_more) ==> {Bitmap}, NEW
    :
    RESULT = New_bitmap(B.Width / K, .Height / K, 24) 
    B.Stretch_draw(RESULT.Canvas, {rect}(Width=RESULT.Width.Pixels_to_points,
    	Height=RESULT.Height.Pixels_to_points))
    .
    
FUN Actual_format(STR Path|_to_image_file) ==> STR :
    {File_stream} in|_temp_file = Read_file_stream(Path) 
    BYTE start|_bytes[]
    NONE = in.Load_bytes(start[], 20)
    in.Close
    STR ss|tart_chars = Bytes_to_ascii(start[0 TO *]).Upper
    CASE ?
    ["PNG" IN ss] ? RESULT = ".png" ==> 
    ["JFIF" IN ss] ? .. = ".jpg" ==>
    ["TIF" IN ss] ? .. = ".tif" ==>
    ["GIF" IN ss] ? .. = ".gif" ==>
    ["WEBP" IN ss] ? ..= ".webp" ==>
    [ss.Starting("BM")] ? ..=".bmp" ==> 
    ;
    RESULT = Path.Lower.Ext .
    
	
END

*/





